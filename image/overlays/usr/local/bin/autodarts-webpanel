    return f"""<!doctype html>
<html lang="de">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  {refresh}
  <title>{html.escape(title)}</title>
  <style>
    body {{ margin: 0; font-family: system-ui, sans-serif; background: #101412; color: #eef7ef; }}
    main {{ max-width: 1040px; margin: 0 auto; padding: 32px 20px; }}
    header {{ display: flex; align-items: center; gap: 18px; margin-bottom: 26px; }}
    img {{ width: 82px; height: 82px; object-fit: contain; }}
    h1 {{ margin: 0; font-size: 32px; }}
    h2 {{ margin-top: 28px; }}
    p {{ color: #b8c7bb; line-height: 1.5; }}
