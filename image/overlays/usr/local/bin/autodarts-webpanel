  <iframe src="{html.escape(frame_url)}" title="{html.escape(label)}"></iframe>
</body>
</html>"""


def redirect(handler, target):
    handler.send_response(303)
    handler.send_header("Location", target)
    handler.end_headers()


def redirect_to_setup(handler):
    handler.send_response(302)
    handler.send_header("Location", "http://auto.setup.go/setup")
    handler.send_header("Cache-Control", "no-store")
    handler.end_headers()


def render_kiosk_portal(config, request_host=""):
    net = network_status()
    autodarts_url = detect_autodarts_url(config)
    manager_url = external_autodarts_url(request_host)
    candidates = ", ".join(html.escape(url) for url in autodarts_url_candidates(config))
    primary_ip = html.escape(net.get("primary_ip") or "noch keine IP")
    install_state = "abgeschlossen" if INSTALL_MARKER.exists() else "laeuft oder wartet auf Netzwerk"
    fallback = html.escape(config.get("autodarts_fallback_url", config.get("play_url", "https://play.autodarts.io")))
    if autodarts_url:
        autodarts_action = f"""<a class="button" href="/app?target=manager">Kameras / Autodarts oeffnen</a>
  <a class="button" href="/app?target=config">Kamera-Setup oeffnen</a>
  <a class="button" href="{html.escape(manager_url)}">Manager direkt oeffnen</a>
  <p class="muted">Lokaler Autodarts-Dienst erkannt: <strong>{html.escape(autodarts_url)}</strong>. Externer Zugriff: <strong>{html.escape(manager_url)}</strong></p>"""
    else:
        autodarts_action = f"""<a class="button" href="/app?target=manager">Autodarts Manager versuchen</a>
  <a class="button" href="/app?target=config">Kamera-Setup versuchen</a>
  <a class="button" href="{html.escape(manager_url)}">Manager direkt oeffnen</a>
  <p class="muted">Die lokale Autodarts-Oberflaeche ist noch nicht bestaetigt erreichbar. Erwartete Adresse: <strong>{html.escape(manager_url)}</strong>. Diese Seite aktualisiert sich automatisch.</p>"""
    content = f"""<section class="panel">
  <h2>Autodarts Pi OS ist bereit</h2>
  <p>Diese lokale Seite bleibt auf Bildschirm und Handy erreichbar. Von hier aus startest du die Autodarts- und Kamera-Einrichtung, sobald der lokale Dienst bereit ist.</p>
  <p>Zugewiesene IP: <strong>{primary_ip}</strong></p>
  <p>Installationsstatus: <strong>{html.escape(install_state)}</strong></p>
  <p>Gepruefte lokale Ziele: <strong>{candidates}</strong></p>
  {autodarts_action}
  <a class="button" href="/kiosk">Status aktualisieren</a>
  <a class="button" href="/admin">Admin</a>
  <a class="button" href="/setup">Netzwerk-Setup</a>
  <a class="button" href="/app?target=play">Autodarts Play</a>
  <a class="button" href="{fallback}">Play direkt oeffnen</a>
</section>"""
    return render_page("Autodarts Pi OS", content, refresh_seconds=10)


class Handler(BaseHTTPRequestHandler):
    def do_POST(self):
        length = int(self.headers.get("Content-Length", "0"))
        data = parse_qs(self.rfile.read(length).decode("utf-8"), keep_blank_values=True)
        config = read_config()

        if self.path == "/login":
            password = data.get("password", [""])[0]
            target = data.get("next", ["/setup"])[0]
            if target not in {"/setup", "/admin"}:
                target = "/setup"
            if password == config.get("setup_admin_password", "autodarts"):
                self.send_response(303)
                self.send_header("Location", target)
                self.send_header("Set-Cookie", f"autodarts_setup={session_token()}; Path=/; HttpOnly; SameSite=Lax")
                self.end_headers()
                return
            redirect(self, f"{target}?login=failed")
            return

        if self.path == "/setup/save":
            if not is_authenticated(self):
                redirect(self, "/setup")
                return
            hostname = data.get("hostname", [""])[0].strip()
            admin_password = data.get("setup_admin_password", [""])[0].strip()
            wifi_ssid = data.get("wifi_ssid", [""])[0].strip()
            wifi_password = data.get("wifi_password", [""])[0]
            wifi_country = data.get("wifi_country", ["DE"])[0].strip().upper()[:2] or "DE"
            if hostname:
                config["hostname"] = hostname
                run_command(["hostnamectl", "set-hostname", hostname])
            if admin_password:
                config["setup_admin_password"] = admin_password
                reset_session_token()
            if wifi_ssid:
                stored_wifi = read_wifi_credentials()
                previous_wifi_password = stored_wifi.get("password") or config.get("wifi_password", "")
                effective_wifi_password = wifi_password if wifi_password else previous_wifi_password
                config["wifi_ssid"] = wifi_ssid
                config["wifi_password"] = effective_wifi_password
                config["wifi_country"] = wifi_country
                write_wifi_credentials(wifi_ssid, effective_wifi_password, wifi_country)
                write_config(config)
                setup_status = read_status()
                if effective_wifi_password:
                    setup_status["wifi"] = {
                        "state": "pending",
                        "message": (
                            "WLAN-Daten gespeichert. Der Setup-Hotspot wird kurz deaktiviert, "
                            "die Verbindung wird getestet und bei Erfolg dauerhaft gespeichert."
                        ),
                        "ssid": wifi_ssid,
                        "password_saved": True,
                    }
                else:
                    setup_status["wifi"] = {
                        "state": "failed",
                        "message": "Es wurde kein WLAN-Passwort gespeichert. Trage das Passwort ein und speichere erneut.",
                        "ssid": wifi_ssid,
                        "password_saved": False,
                    }
                write_status(setup_status)
                if effective_wifi_password:
                    WIFI_APPLY_REQUEST.parent.mkdir(parents=True, exist_ok=True)
                    WIFI_APPLY_REQUEST.write_text("pending\n", encoding="utf-8")
            else:
                setup_status = read_status()
                setup_status["wifi"] = {"state": "skipped", "message": "WLAN wurde uebersprungen."}
                write_status(setup_status)
            write_config(config)
            current_network = network_status()
            if not wifi_ssid and current_network["online"]:
                setup_status = read_status()
                mark_setup_configured(
                    config,
                    setup_status,
                    "Setup wurde ueber Ethernet gespeichert und abgeschlossen. Der Kiosk startet danach den Autodarts-Konfigurationsmodus.",
                )
            redirect(self, "/setup?saved=1")
            return

        if self.path == "/setup/finish":
            if not is_authenticated(self):
                redirect(self, "/setup")
                return
            status = read_status()
            status["network"] = network_status()
            if not status["network"]["online"]:
                status["finish"] = {
                    "state": "failed",
                    "message": "Setup kann nicht abgeschlossen werden, solange weder Ethernet noch WLAN verbunden ist.",
                }
                write_status(status)
                config["setup_mode"] = "true"
                write_config(config)
                redirect(self, "/setup?finish=network-missing")
                return
            status["finish"] = {"state": "ok", "message": "Setup abgeschlossen."}
            mark_setup_configured(config, status, "Setup abgeschlossen.")
            redirect(self, "/kiosk")
            return

        if self.path == "/admin/recovery":
            if not is_authenticated(self):
                redirect(self, "/admin")
                return
            if data.get("confirm_recovery", [""])[0] != "yes":
                status = read_status()
                status["admin"] = {"state": "warning", "message": "Recovery-Hotspot wurde nicht gestartet. Bitte zuerst bestaetigen."}
                write_status(status)
                redirect(self, "/admin")
                return
            config["setup_mode"] = "true"
            write_config(config)
            write_setup_state("recovery")
            redirect(self, "/setup")
            return

        if self.path == "/admin/factory-reset":
            if not is_authenticated(self):
                redirect(self, "/admin")
                return
            if data.get("confirm_factory_reset", [""])[0] != "yes":
                status = read_status()
                status["admin"] = {"state": "warning", "message": "Factory Reset wurde nicht ausgefuehrt. Bitte zuerst bestaetigen."}
                write_status(status)
                redirect(self, "/admin")
                return
            status = read_status()
            status["factory_reset"] = {"state": "requested", "message": "Factory Reset wurde angefordert."}
            status.pop("admin", None)
            write_status(status)
            if DEFAULT_CONFIG.exists():
                CONFIG.write_text(DEFAULT_CONFIG.read_text(encoding="utf-8"), encoding="utf-8")
                config = read_config()
            config["setup_mode"] = "true"
            write_config(config)
            write_setup_state("factory")
            redirect(self, "/setup")
            return

        self.send_response(404)
        self.end_headers()

    def do_GET(self):
        path = urlparse(self.path).path
        config = read_config()

        captive_probe_paths = {
            "/generate_204",
            "/gen_204",
            "/hotspot-detect.html",
            "/library/test/success.html",
            "/success.txt",
            "/connecttest.txt",
            "/ncsi.txt",
        }
        if read_setup_state() != "configured" and path in captive_probe_paths:
            redirect_to_setup(self)
            return

        if path == "/":
            redirect(self, "/kiosk" if read_setup_state() == "configured" else "/setup")
            return

        if path == "/kiosk":
            if read_setup_state() != "configured" or str(config.get("setup_mode", "true")).lower() != "false":
                redirect(self, "/setup")
                return
            payload = render_kiosk_portal(config, self.headers.get("Host", "")).encode("utf-8")
            self.send_response(200)
            self.send_header("Content-Type", "text/html; charset=utf-8")
            self.send_header("Content-Length", str(len(payload)))
            self.end_headers()
            self.wfile.write(payload)
            return

        if path == "/app":
            if read_setup_state() != "configured" or str(config.get("setup_mode", "true")).lower() != "false":
                redirect(self, "/setup")
                return
            query = parse_qs(urlparse(self.path).query, keep_blank_values=True)
            target = query.get("target", ["manager"])[0]
            payload = render_kiosk_shell(config, self.headers.get("Host", ""), target).encode("utf-8")
            self.send_response(200)
            self.send_header("Content-Type", "text/html; charset=utf-8")
            self.send_header("Content-Length", str(len(payload)))
            self.end_headers()
            self.wfile.write(payload)
            return

        if path in {"/autodarts", "/camera"}:
            autodarts_url = detect_autodarts_url(config)
            if autodarts_url:
                redirect(self, "/app?target=config" if path == "/camera" else "/app?target=manager")
                return
            redirect(self, "/kiosk")
            return

        if path == "/splash.png":
            if SPLASH.exists():
                payload = SPLASH.read_bytes()
                self.send_response(200)
                self.send_header("Content-Type", "image/png")
                self.send_header("Content-Length", str(len(payload)))
                self.end_headers()
                self.wfile.write(payload)
            else:
                self.send_response(404)
                self.end_headers()
            return

        if path == "/health.json":
            payload = {
                "hostname": socket.gethostname(),
                "config": public_config(config),
                "setup": read_status(),
                "setup_state": read_setup_state(),
                "autodarts_install_done": INSTALL_MARKER.exists(),
                "autodarts_detected_url": detect_autodarts_url(config),
                "network": network_status(),
                "services": {
                    "install": service_state("autodarts-install.service"),
                    "runtime": service_state("autodarts-runtime.service"),
                    "upstream": service_state("autodarts.service"),
                    "watchdog": service_state("autodarts-watchdog.service"),
                    "webpanel": service_state("autodarts-webpanel.service"),
                },
            }
            body = json.dumps(payload, indent=2).encode("utf-8")
            self.send_response(200)
            self.send_header("Content-Type", "application/json")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)
            return

        if path == "/logs/kiosk":
            payload = KIOSK_LOG.read_text(encoding="utf-8", errors="replace")[-12000:] if KIOSK_LOG.exists() else "No kiosk log yet."
            body = payload.encode("utf-8")
            self.send_response(200)
            self.send_header("Content-Type", "text/plain; charset=utf-8")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)
            return

        if path == "/logs/network":
            payload = NETWORK_LOG.read_text(encoding="utf-8", errors="replace")[-12000:] if NETWORK_LOG.exists() else "No network log yet."
            body = payload.encode("utf-8")
            self.send_response(200)
            self.send_header("Content-Type", "text/plain; charset=utf-8")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)
            return

        if path == "/logs/firstboot":
            payload = FIRSTBOOT_LOG.read_text(encoding="utf-8", errors="replace")[-12000:] if FIRSTBOOT_LOG.exists() else "No firstboot log yet."
            body = payload.encode("utf-8")
            self.send_response(200)
            self.send_header("Content-Type", "text/plain; charset=utf-8")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)
            return

        if path == "/logs/install":
            payload = INSTALL_LOG.read_text(encoding="utf-8", errors="replace")[-12000:] if INSTALL_LOG.exists() else "No install log yet."
            body = payload.encode("utf-8")
            self.send_response(200)
            self.send_header("Content-Type", "text/plain; charset=utf-8")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)
            return

        if path == "/admin":
            if not is_authenticated(self):
                body = render_page(
                    "Autodarts Pi OS Admin Login",
                    """<div class="panel"><p>Bitte melde dich am lokalen Adminbereich an.</p></div>
<form method="post" action="/login">
  <input type="hidden" name="next" value="/admin">
  <label for="password">Admin-Passwort</label>
  <input id="password" name="password" type="password" autocomplete="current-password" autofocus>
  <button type="submit">Einloggen</button>
</form>""",
                ).encode("utf-8")
                self.send_response(200)
                self.send_header("Content-Type", "text/html; charset=utf-8")
                self.send_header("Content-Length", str(len(body)))
                self.end_headers()
                self.wfile.write(body)
                return

            net = network_status()
            status = read_status()
            services = {
                "Autodarts Runtime": service_state("autodarts-runtime.service"),
                "Autodarts Install": service_state("autodarts-install.service"),
                "Webpanel": service_state("autodarts-webpanel.service"),
                "Network": service_state("autodarts-network.service"),
                "Watchdog": service_state("autodarts-watchdog.service"),
            }
            service_rows = "".join(f"<tr><th>{html.escape(key)}</th><td>{html.escape(value)}</td></tr>" for key, value in services.items())
            primary_ip = html.escape(net.get("primary_ip") or "noch keine IP")
            install_log = html.escape(tail_file(INSTALL_LOG, "Noch kein Installationslog vorhanden.", 12000))
            admin_status = status.get("admin", {})
            admin_notice = ""
            if admin_status:
                admin_notice = f"""<div class="panel"><p><strong>{html.escape(admin_status.get("message", ""))}</strong></p></div>"""
            content = f"""{admin_notice}<div class="panel"><h2>Status</h2><p>Setup-Zustand: <strong>{html.escape(read_setup_state())}</strong></p><p>Zugewiesene IP: <strong>{primary_ip}</strong></p><p>Ethernet: {html.escape(str(net["ethernet_connected"]))} | WLAN: {html.escape(str(net["wifi_connected"]))} | Hotspot: {html.escape(str(net["setup_hotspot_active"]))}</p><pre>{html.escape(net["ip_addresses"]["stdout"])}</pre></div>
<section><h2>Dienste</h2><table>{service_rows}</table></section>
<section class="panel"><h2>Aktionen</h2>
  <a class="button" href="/setup">Setup öffnen</a>
  <a class="button" href="/health.json">Systemstatus</a>
  <a class="button" href="/logs/kiosk">Kiosk-Log</a>
  <a class="button" href="/logs/firstboot">Firstboot-Log</a>
  <a class="button" href="/logs/network">Netzwerk-Log</a>
  <a class="button" href="/logs/install">Install-Log</a>
  <form method="post" action="/admin/recovery">
    <label><input type="checkbox" name="confirm_recovery" value="yes"> Recovery-Hotspot wirklich starten</label>
    <button type="submit">Recovery-Hotspot starten</button>
  </form>
  <form method="post" action="/admin/factory-reset">
    <label><input type="checkbox" name="confirm_factory_reset" value="yes"> System wirklich auf Werkseinstellungen zuruecksetzen</label>
    <button type="submit">Factory Reset ausfuehren</button>
  </form>
</section>
<section class="panel"><h2>Installationslog</h2><pre class="log-box">{install_log}</pre></section>
<section><h2>Letzter Setup-Status</h2><pre>{html.escape(json.dumps(status, indent=2))}</pre></section>"""
            payload = render_page("Autodarts Pi OS Admin", content).encode("utf-8")
            self.send_response(200)
            self.send_header("Content-Type", "text/html; charset=utf-8")
            self.send_header("Content-Length", str(len(payload)))
            self.end_headers()
            self.wfile.write(payload)
            return

        if path == "/setup":
            if not is_authenticated(self):
                body = render_page(
                    "Autodarts Pi OS Login",
                    """<div class="panel"><p>Bitte melde dich am lokalen Setup an. Standard beim ersten Start: Passwort <strong>autodarts</strong>.</p></div>
<form method="post" action="/login">
  <input type="hidden" name="next" value="/setup">
  <label for="password">Setup-Passwort</label>
  <input id="password" name="password" type="password" autocomplete="current-password" autofocus>
  <button type="submit">Einloggen</button>
</form>""",
                ).encode("utf-8")
                self.send_response(200)
                self.send_header("Content-Type", "text/html; charset=utf-8")
                self.send_header("Content-Length", str(len(body)))
                self.end_headers()
                self.wfile.write(body)
                return

            status = read_status()
            net = network_status()
            net_state = "online" if net["online"] else "offline"
            hotspot_note = ""
            if net["setup_hotspot_active"]:
                hotspot_note = f"""<p>Setup-Hotspot: <strong>{html.escape(config.get("setup_hotspot_ssid", "Autodarts-Setup"))}</strong><br>Adresse: <strong>http://{html.escape(config.get("setup_hotspot_host", "auto.setup.go"))}</strong><br>Passwort: <strong>{html.escape(config.get("setup_hotspot_password", "autodarts"))}</strong></p>"""
            finish = status.get("finish", {})
            finish_note = f"""<p>Status Setup-Abschluss: <strong>{html.escape(str(finish.get("state", "")))}</strong> {html.escape(str(finish.get("message", "")))}</p>""" if finish else ""
            primary_ip = html.escape(net.get("primary_ip") or "noch keine IP")
            net_panel = f"""<section class="panel"><h2>Netzwerk</h2><p>Status: <strong>{net_state}</strong></p><p>Zugewiesene IP: <strong>{primary_ip}</strong></p><p>Ethernet: {html.escape(str(net["ethernet_connected"]))} | WLAN: {html.escape(str(net["wifi_connected"]))} | Setup-Hotspot: {html.escape(str(net["setup_hotspot_active"]))}</p>{hotspot_note}{finish_note}<pre>{html.escape(net["devices"]["stdout"])}</pre><pre>{html.escape(net["ip_addresses"]["stdout"])}</pre></section>"""
            wifi = status.get("wifi", {})
            wifi_panel = ""
            if wifi:
                state = html.escape(str(wifi.get("state", "")))
                message = html.escape(str(wifi.get("message", "")))
                assigned_ip = html.escape(str(wifi.get("assigned_ip", "")))
                stdout = html.escape(str(wifi.get("stdout", "")))
                stderr = html.escape(str(wifi.get("stderr", "")))
                reconnect_note = ""
                if str(wifi.get("state", "")) in {"pending", "running"}:
                    reconnect_note = """<p class="muted">Die Verbindung zu dieser Setup-Seite kann gleich abbrechen. Warte etwa eine Minute. Wenn die WLAN-Daten stimmen, verbinde dein Handy mit deinem Heim-WLAN und oeffne <strong>http://autodarts-pi.local</strong>. Wenn sie nicht stimmen, erscheint der Hotspot <strong>Autodarts-Setup</strong> wieder.</p>"""
                ip_note = f"""<p>Zugewiesene WLAN-IP: <strong>{assigned_ip}</strong></p>""" if assigned_ip else ""
                wifi_panel = f"""<section class="panel"><h2>WLAN-Status</h2><p>Status: <strong>{state}</strong></p>{ip_note}<p>{message}</p>{reconnect_note}<pre>{stdout}</pre><pre>{stderr}</pre></section>"""
            else:
                current_wifi = wifi_status()
                wifi_panel = f"""<section class="panel"><h2>WLAN-Status</h2><pre>{html.escape(current_wifi.get("stdout", ""))}</pre><pre>{html.escape(current_wifi.get("stderr", ""))}</pre></section>"""

            config_rows = "".join(f"<tr><th>{html.escape(key)}</th><td>{html.escape(value)}</td></tr>" for key, value in public_config(config).items())
            stored_wifi = read_wifi_credentials()
            saved_password_note = "gespeichert" if stored_wifi.get("password_saved") else "nicht gespeichert"
            content = f"""<p class="muted">Richte das System wie bei einem Router ein: erst lokales Setup-Passwort und Hostname. Mit Netzwerkkabel wird das Setup beim Speichern abgeschlossen. Mit WLAN passiert das nach erfolgreichem Verbindungstest.</p>
{net_panel}
{wifi_panel}
<form method="post" action="/setup/save">
  <h2>System</h2>
  <label for="hostname">Hostname</label>
  <input id="hostname" name="hostname" value="{html.escape(config.get("hostname", "autodarts-pi"))}">
  <label for="setup_admin_password">Neues Setup-Passwort</label>
  <input id="setup_admin_password" name="setup_admin_password" type="password" placeholder="leer lassen, wenn unveraendert">
  <h2>WLAN</h2>
  <p class="muted">Leer lassen, wenn du Ethernet verwendest. Dann wird das Setup beim Speichern dauerhaft abgeschlossen.</p>
  <label for="wifi_ssid">WLAN-Name</label>
  <input id="wifi_ssid" name="wifi_ssid" value="{html.escape(config.get("wifi_ssid", ""))}">
  <label for="wifi_password">WLAN-Passwort</label>
  <input id="wifi_password" name="wifi_password" type="password" placeholder="leer lassen, um gespeichertes Passwort zu behalten">
  <p class="muted">Passwortstatus: <strong>{html.escape(saved_password_note)}</strong></p>
  <label for="wifi_country">Land</label>
  <input id="wifi_country" name="wifi_country" value="{html.escape(config.get("wifi_country", "DE"))}">
  <button type="submit">Speichern und anwenden</button>
</form>
<form method="post" action="/setup/finish">
  <h2>Setup abschliessen</h2>
  <p class="muted">Falls das Setup noch nicht automatisch abgeschlossen wurde, kannst du es hier manuell abschliessen. Danach startet der Kiosk auf Autodarts Play statt auf diesem Setup.</p>
  <button type="submit">Setup abschliessen</button>
</form>
<section>
  <a class="button" href="/health.json">Systemstatus</a>
  <a class="button" href="/logs/kiosk">Kiosk-Log</a>
  <a class="button" href="https://play.autodarts.io">Autodarts Play</a>
</section>
<section><h2>Aktuelle Konfiguration</h2><table>{config_rows}</table></section>"""
            payload = render_page("Autodarts Pi OS Setup", content).encode("utf-8")
            self.send_response(200)
            self.send_header("Content-Type", "text/html; charset=utf-8")
            self.send_header("Content-Length", str(len(payload)))
            self.end_headers()
            self.wfile.write(payload)
            return

        status = {
            "Runtime": service_state("autodarts-runtime.service"),
            "Watchdog": service_state("autodarts-watchdog.service"),
            "Web panel": service_state("autodarts-webpanel.service"),
        }
        rows = "".join(
            f"<tr><th>{html.escape(key)}</th><td>{html.escape(value)}</td></tr>"
            for key, value in status.items()
        )
        config_rows = "".join(
            f"<tr><th>{html.escape(key)}</th><td>{html.escape(value)}</td></tr>"
            for key, value in public_config(config).items()
        )
        body = f"""<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Autodarts Pi OS</title>
  <style>
    body {{ margin: 0; font-family: system-ui, sans-serif; background: #101412; color: #eef7ef; }}
    main {{ max-width: 960px; margin: 0 auto; padding: 32px 20px; }}
    header {{ display: flex; align-items: center; gap: 18px; margin-bottom: 28px; }}
    img {{ width: 96px; height: 96px; object-fit: contain; }}
    h1 {{ margin: 0; font-size: 32px; }}
    p {{ color: #b8c7bb; }}
    section {{ margin-top: 24px; }}
    table {{ width: 100%; border-collapse: collapse; background: #171d1a; border: 1px solid #2b3830; }}
    th, td {{ text-align: left; padding: 12px 14px; border-bottom: 1px solid #2b3830; }}
    th {{ width: 190px; color: #9ee26d; }}
    a {{ color: #9ee26d; }}
  </style>
</head>
<body>
  <main>
    <header>
      <img src="/splash.png" alt="">
      <div>
        <h1>Autodarts Pi OS</h1>
        <p>{html.escape(socket.gethostname())}</p>
      </div>
    </header>
    <section><h2>Services</h2><table>{rows}</table></section>
    <section><h2>Configuration</h2><table>{config_rows}</table></section>
    <p><a href="/health.json">health.json</a></p>
  </main>
</body>
</html>"""
        payload = body.encode("utf-8")
        self.send_response(200)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.send_header("Content-Length", str(len(payload)))
        self.end_headers()
        self.wfile.write(payload)

    def log_message(self, format, *args):
        return


if __name__ == "__main__":
    config = read_config()
    port = int(config.get("webpanel_port", PORT))
    HTTPServer(("0.0.0.0", port), Handler).serve_forever()
