#!/usr/bin/env python3
from http.server import BaseHTTPRequestHandler, HTTPServer
from pathlib import Path
from http import cookies
import html
import json
import secrets
import socket
import subprocess
from urllib.parse import parse_qs, urlparse

CONFIG = Path("/etc/autodarts-pi-os/config.toml")
DEFAULT_CONFIG = Path("/usr/share/autodarts-pi-os/default-config.toml")
SPLASH = Path("/usr/share/autodarts-pi-os/splash.png")
STATUS_FILE = Path("/var/lib/autodarts-pi-os/setup-status.json")
SETUP_STATE = Path("/var/lib/autodarts-pi-os/setup.state")
KIOSK_LOG = Path("/var/log/autodarts-kiosk.log")
NETWORK_LOG = Path("/var/log/autodarts-network.log")
INSTALL_LOG = Path("/var/log/autodarts-install.log")
SESSION_FILE = Path("/var/lib/autodarts-pi-os/webpanel-session")
PORT = 80


def read_config():
    if not CONFIG.exists():
        return {}
    values = {}
    for line in CONFIG.read_text(encoding="utf-8").splitlines():
        if "=" not in line or line.strip().startswith("#"):
            continue
        key, value = line.split("=", 1)
        values[key.strip()] = value.strip().strip('"')
    return values


def write_config(values):
    lines = []
    for key, value in values.items():
        if isinstance(value, bool):
            rendered = "true" if value else "false"
        elif str(value).lower() in {"true", "false"}:
            rendered = str(value).lower()
        elif str(value).isdigit():
            rendered = str(value)
        else:
            rendered = f'"{str(value)}"'
        lines.append(f"{key} = {rendered}")
    CONFIG.write_text("\n".join(lines) + "\n", encoding="utf-8")


def public_config(values):
    redacted = {}
    for key, value in values.items():
        if "password" in key:
            redacted[key] = "********" if value else ""
        else:
            redacted[key] = value
    return redacted


def session_token():
    SESSION_FILE.parent.mkdir(parents=True, exist_ok=True)
    if not SESSION_FILE.exists():
        SESSION_FILE.write_text(secrets.token_urlsafe(32), encoding="utf-8")
    return SESSION_FILE.read_text(encoding="utf-8").strip()


def reset_session_token():
    SESSION_FILE.parent.mkdir(parents=True, exist_ok=True)
    SESSION_FILE.write_text(secrets.token_urlsafe(32), encoding="utf-8")


def service_state(name):
    try:
        result = subprocess.run(
            ["systemctl", "is-active", name],
            text=True,
            capture_output=True,
            timeout=3,
            check=False,
        )
        return result.stdout.strip() or result.stderr.strip() or "unknown"
    except Exception as exc:
        return f"unavailable: {exc}"


def run_command(command):
    try:
        result = subprocess.run(
            command,
            text=True,
            capture_output=True,
            timeout=75,
            check=False,
        )
        return result.returncode, result.stdout.strip(), result.stderr.strip()
    except Exception as exc:
        return 1, "", str(exc)


def read_status():
    if not STATUS_FILE.exists():
        return {}
    try:
        return json.loads(STATUS_FILE.read_text(encoding="utf-8"))
    except Exception:
        return {}


def write_status(values):
    STATUS_FILE.parent.mkdir(parents=True, exist_ok=True)
    STATUS_FILE.write_text(json.dumps(values, indent=2), encoding="utf-8")


def read_setup_state():
    if not SETUP_STATE.exists():
        return "factory"
    value = SETUP_STATE.read_text(encoding="utf-8").strip()
    return value or "factory"


def write_setup_state(value):
    SETUP_STATE.parent.mkdir(parents=True, exist_ok=True)
    SETUP_STATE.write_text(value + "\n", encoding="utf-8")


def wifi_status():
    code, stdout, stderr = run_command(["nmcli", "-t", "-f", "DEVICE,TYPE,STATE,CONNECTION", "device"])
    return {
        "returncode": code,
        "stdout": stdout,
        "stderr": stderr,
    }


def network_status():
    device_code, device_stdout, device_stderr = run_command(["nmcli", "-t", "-f", "DEVICE,TYPE,STATE,CONNECTION", "device"])
    general_code, general_stdout, general_stderr = run_command(["nmcli", "-t", "-f", "STATE,CONNECTIVITY", "general"])
    ip_code, ip_stdout, ip_stderr = run_command(["hostname", "-I"])
    ethernet_connected = any(
        line.split(":")[1:3] == ["ethernet", "connected"]
        for line in device_stdout.splitlines()
        if len(line.split(":")) >= 3
    )
    wifi_connected = any(
        line.split(":")[1:3] == ["wifi", "connected"]
        for line in device_stdout.splitlines()
        if len(line.split(":")) >= 3
    )
    setup_hotspot_active = any(
        len(line.split(":")) >= 4 and line.split(":")[3] == "Autodarts-Setup"
        for line in device_stdout.splitlines()
    )
    return {
        "online": ethernet_connected or wifi_connected,
        "ethernet_connected": ethernet_connected,
        "wifi_connected": wifi_connected,
        "setup_hotspot_active": setup_hotspot_active,
        "devices": {
            "returncode": device_code,
            "stdout": device_stdout,
            "stderr": device_stderr,
        },
        "general": {
            "returncode": general_code,
            "stdout": general_stdout,
            "stderr": general_stderr,
        },
        "ip_addresses": {
            "returncode": ip_code,
            "stdout": ip_stdout,
            "stderr": ip_stderr,
        },
    }


def is_authenticated(handler):
    header = handler.headers.get("Cookie", "")
    jar = cookies.SimpleCookie()
    jar.load(header)
    return jar.get("autodarts_setup") and jar["autodarts_setup"].value == session_token()


def render_page(title, content):
    return f"""<!doctype html>
<html lang="de">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{html.escape(title)}</title>
  <style>
    body {{ margin: 0; font-family: system-ui, sans-serif; background: #101412; color: #eef7ef; }}
    main {{ max-width: 1040px; margin: 0 auto; padding: 32px 20px; }}
    header {{ display: flex; align-items: center; gap: 18px; margin-bottom: 26px; }}
    img {{ width: 82px; height: 82px; object-fit: contain; }}
    h1 {{ margin: 0; font-size: 32px; }}
    h2 {{ margin-top: 28px; }}
    p {{ color: #b8c7bb; line-height: 1.5; }}
    form, .panel {{ background: #171d1a; border: 1px solid #2b3830; padding: 18px; margin-top: 16px; }}
    label {{ display: block; color: #9ee26d; font-weight: 700; margin-top: 12px; }}
    input {{ box-sizing: border-box; width: 100%; padding: 11px; margin-top: 6px; background: #0d110f; color: #eef7ef; border: 1px solid #3a473f; }}
    button, a.button {{ display: inline-block; margin-top: 16px; margin-right: 10px; padding: 10px 14px; border: 0; background: #9ee26d; color: #101412; text-decoration: none; font-weight: 800; cursor: pointer; }}
    table {{ width: 100%; border-collapse: collapse; background: #171d1a; border: 1px solid #2b3830; }}
    th, td {{ text-align: left; padding: 11px 13px; border-bottom: 1px solid #2b3830; }}
    th {{ width: 220px; color: #9ee26d; }}
    .muted {{ color: #b8c7bb; }}
  </style>
</head>
<body>
  <main>
    <header>
      <img src="/splash.png" alt="">
      <div>
        <h1>{html.escape(title)}</h1>
        <p>{html.escape(socket.gethostname())}</p>
      </div>
    </header>
    {content}
  </main>
</body>
</html>"""


def redirect(handler, target):
    handler.send_response(303)
    handler.send_header("Location", target)
    handler.end_headers()


class Handler(BaseHTTPRequestHandler):
    def do_POST(self):
        length = int(self.headers.get("Content-Length", "0"))
        data = parse_qs(self.rfile.read(length).decode("utf-8"))
        config = read_config()

        if self.path == "/login":
            password = data.get("password", [""])[0]
            target = data.get("next", ["/setup"])[0]
            if target not in {"/setup", "/admin"}:
                target = "/setup"
            if password == config.get("setup_admin_password", "autodarts"):
                self.send_response(303)
                self.send_header("Location", target)
                self.send_header("Set-Cookie", f"autodarts_setup={session_token()}; Path=/; HttpOnly; SameSite=Lax")
                self.end_headers()
                return
            redirect(self, f"{target}?login=failed")
            return

        if self.path == "/setup/save":
            if not is_authenticated(self):
                redirect(self, "/setup")
                return
            hostname = data.get("hostname", [""])[0].strip()
            admin_password = data.get("setup_admin_password", [""])[0].strip()
            wifi_ssid = data.get("wifi_ssid", [""])[0].strip()
            wifi_password = data.get("wifi_password", [""])[0]
            wifi_country = data.get("wifi_country", ["DE"])[0].strip().upper()[:2] or "DE"
            if hostname:
                config["hostname"] = hostname
                run_command(["hostnamectl", "set-hostname", hostname])
            if admin_password:
                config["setup_admin_password"] = admin_password
                reset_session_token()
            if wifi_ssid:
                config["wifi_ssid"] = wifi_ssid
                config["wifi_country"] = wifi_country
                setup_status = read_status()
                setup_status["wifi"] = {"state": "running", "message": "WLAN-Verbindung wird eingerichtet."}
                write_status(setup_status)
                run_command(["rfkill", "unblock", "wifi"])
                run_command(["nmcli", "radio", "wifi", "on"])
                run_command(["nmcli", "device", "wifi", "rescan"])
                command = ["nmcli", "--wait", "60", "dev", "wifi", "connect", wifi_ssid]
                if wifi_password:
                    command.extend(["password", wifi_password])
                code, stdout, stderr = run_command(command)
                setup_status["wifi"] = {
                    "state": "ok" if code == 0 else "failed",
                    "returncode": code,
                    "stdout": stdout,
                    "stderr": stderr,
                    "status": wifi_status(),
                }
                write_status(setup_status)
                config["setup_mode"] = "true" if code != 0 else config.get("setup_mode", "true")
            else:
                setup_status = read_status()
                setup_status["wifi"] = {"state": "skipped", "message": "WLAN wurde uebersprungen."}
                write_status(setup_status)
            write_config(config)
            redirect(self, "/setup?saved=1")
            return

        if self.path == "/setup/finish":
            if not is_authenticated(self):
                redirect(self, "/setup")
                return
            status = read_status()
            status["network"] = network_status()
            if not status["network"]["online"]:
                status["finish"] = {
                    "state": "failed",
                    "message": "Setup kann nicht abgeschlossen werden, solange weder Ethernet noch WLAN verbunden ist.",
                }
                write_status(status)
                config["setup_mode"] = "true"
                write_config(config)
                redirect(self, "/setup?finish=network-missing")
                return
            status["finish"] = {"state": "ok", "message": "Setup abgeschlossen."}
            write_status(status)
            config["setup_mode"] = "false"
            write_config(config)
            write_setup_state("configured")
            redirect(self, config.get("play_url", "https://play.autodarts.io"))
            return

        if self.path == "/admin/recovery":
            if not is_authenticated(self):
                redirect(self, "/admin")
                return
            config["setup_mode"] = "true"
            write_config(config)
            write_setup_state("recovery")
            redirect(self, "/setup")
            return

        if self.path == "/admin/factory-reset":
            if not is_authenticated(self):
                redirect(self, "/admin")
                return
            status = read_status()
            status["factory_reset"] = {"state": "requested", "message": "Factory Reset wurde angefordert."}
            write_status(status)
            if DEFAULT_CONFIG.exists():
                CONFIG.write_text(DEFAULT_CONFIG.read_text(encoding="utf-8"), encoding="utf-8")
                config = read_config()
            config["setup_mode"] = "true"
            write_config(config)
            write_setup_state("factory")
            redirect(self, "/setup")
            return

        self.send_response(404)
        self.end_headers()

    def do_GET(self):
        path = urlparse(self.path).path
        config = read_config()
        if path == "/":
            redirect(self, "/admin" if read_setup_state() == "configured" else "/setup")
            return

        if path == "/splash.png":
            if SPLASH.exists():
                payload = SPLASH.read_bytes()
                self.send_response(200)
                self.send_header("Content-Type", "image/png")
                self.send_header("Content-Length", str(len(payload)))
                self.end_headers()
                self.wfile.write(payload)
            else:
                self.send_response(404)
                self.end_headers()
            return

        if path == "/health.json":
            payload = {
                "hostname": socket.gethostname(),
                "config": public_config(config),
                "setup": read_status(),
                "setup_state": read_setup_state(),
                "network": network_status(),
                "services": {
                    "runtime": service_state("autodarts-runtime.service"),
                    "watchdog": service_state("autodarts-watchdog.service"),
                    "webpanel": service_state("autodarts-webpanel.service"),
                },
            }
            body = json.dumps(payload, indent=2).encode("utf-8")
            self.send_response(200)
            self.send_header("Content-Type", "application/json")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)
            return

        if path == "/logs/kiosk":
            payload = KIOSK_LOG.read_text(encoding="utf-8", errors="replace")[-12000:] if KIOSK_LOG.exists() else "No kiosk log yet."
            body = payload.encode("utf-8")
            self.send_response(200)
            self.send_header("Content-Type", "text/plain; charset=utf-8")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)
            return

        if path == "/logs/network":
            payload = NETWORK_LOG.read_text(encoding="utf-8", errors="replace")[-12000:] if NETWORK_LOG.exists() else "No network log yet."
            body = payload.encode("utf-8")
            self.send_response(200)
            self.send_header("Content-Type", "text/plain; charset=utf-8")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)
            return

        if path == "/logs/install":
            payload = INSTALL_LOG.read_text(encoding="utf-8", errors="replace")[-12000:] if INSTALL_LOG.exists() else "No install log yet."
            body = payload.encode("utf-8")
            self.send_response(200)
            self.send_header("Content-Type", "text/plain; charset=utf-8")
            self.send_header("Content-Length", str(len(body)))
            self.end_headers()
            self.wfile.write(body)
            return

        if path == "/admin":
            if not is_authenticated(self):
                body = render_page(
                    "Autodarts Pi OS Admin Login",
                    """<div class="panel"><p>Bitte melde dich am lokalen Adminbereich an.</p></div>
<form method="post" action="/login">
  <input type="hidden" name="next" value="/admin">
  <label for="password">Admin-Passwort</label>
  <input id="password" name="password" type="password" autocomplete="current-password" autofocus>
  <button type="submit">Einloggen</button>
</form>""",
                ).encode("utf-8")
                self.send_response(200)
                self.send_header("Content-Type", "text/html; charset=utf-8")
                self.send_header("Content-Length", str(len(body)))
                self.end_headers()
                self.wfile.write(body)
                return

            net = network_status()
            status = read_status()
            services = {
                "Autodarts Runtime": service_state("autodarts-runtime.service"),
                "Autodarts Install": service_state("autodarts-install.service"),
                "Webpanel": service_state("autodarts-webpanel.service"),
                "Network": service_state("autodarts-network.service"),
                "Watchdog": service_state("autodarts-watchdog.service"),
            }
            service_rows = "".join(f"<tr><th>{html.escape(key)}</th><td>{html.escape(value)}</td></tr>" for key, value in services.items())
            content = f"""<div class="panel"><h2>Status</h2><p>Setup-Zustand: <strong>{html.escape(read_setup_state())}</strong></p><p>Ethernet: {html.escape(str(net["ethernet_connected"]))} | WLAN: {html.escape(str(net["wifi_connected"]))} | Hotspot: {html.escape(str(net["setup_hotspot_active"]))}</p><pre>{html.escape(net["ip_addresses"]["stdout"])}</pre></div>
<section><h2>Dienste</h2><table>{service_rows}</table></section>
<section class="panel"><h2>Aktionen</h2>
  <a class="button" href="/setup">Setup öffnen</a>
  <a class="button" href="/health.json">Systemstatus</a>
  <a class="button" href="/logs/kiosk">Kiosk-Log</a>
  <a class="button" href="/logs/network">Netzwerk-Log</a>
  <a class="button" href="/logs/install">Install-Log</a>
  <form method="post" action="/admin/recovery"><button type="submit">Recovery-Hotspot starten</button></form>
  <form method="post" action="/admin/factory-reset"><button type="submit">Factory Reset vorbereiten</button></form>
</section>
<section><h2>Letzter Setup-Status</h2><pre>{html.escape(json.dumps(status, indent=2))}</pre></section>"""
            payload = render_page("Autodarts Pi OS Admin", content).encode("utf-8")
            self.send_response(200)
            self.send_header("Content-Type", "text/html; charset=utf-8")
            self.send_header("Content-Length", str(len(payload)))
            self.end_headers()
            self.wfile.write(payload)
            return

        if path == "/setup":
            if not is_authenticated(self):
                body = render_page(
                    "Autodarts Pi OS Login",
                    """<div class="panel"><p>Bitte melde dich am lokalen Setup an. Standard beim ersten Start: Passwort <strong>autodarts</strong>.</p></div>
<form method="post" action="/login">
  <input type="hidden" name="next" value="/setup">
  <label for="password">Setup-Passwort</label>
  <input id="password" name="password" type="password" autocomplete="current-password" autofocus>
  <button type="submit">Einloggen</button>
</form>""",
                ).encode("utf-8")
                self.send_response(200)
                self.send_header("Content-Type", "text/html; charset=utf-8")
                self.send_header("Content-Length", str(len(body)))
                self.end_headers()
                self.wfile.write(body)
                return

            status = read_status()
            net = network_status()
            net_state = "online" if net["online"] else "offline"
            hotspot_note = ""
            if net["setup_hotspot_active"]:
                hotspot_note = f"""<p>Setup-Hotspot: <strong>{html.escape(config.get("setup_hotspot_ssid", "Autodarts-Setup"))}</strong><br>Adresse: <strong>http://{html.escape(config.get("setup_hotspot_host", "auto.setup.go"))}</strong><br>Passwort: <strong>{html.escape(config.get("setup_hotspot_password", "autodarts"))}</strong></p>"""
            finish = status.get("finish", {})
            finish_note = f"""<p>Status Setup-Abschluss: <strong>{html.escape(str(finish.get("state", "")))}</strong> {html.escape(str(finish.get("message", "")))}</p>""" if finish else ""
            net_panel = f"""<section class="panel"><h2>Netzwerk</h2><p>Status: <strong>{net_state}</strong></p><p>Ethernet: {html.escape(str(net["ethernet_connected"]))} | WLAN: {html.escape(str(net["wifi_connected"]))} | Setup-Hotspot: {html.escape(str(net["setup_hotspot_active"]))}</p>{hotspot_note}{finish_note}<pre>{html.escape(net["devices"]["stdout"])}</pre><pre>{html.escape(net["ip_addresses"]["stdout"])}</pre></section>"""
            wifi = status.get("wifi", {})
            wifi_panel = ""
            if wifi:
                state = html.escape(str(wifi.get("state", "")))
                stdout = html.escape(str(wifi.get("stdout", "")))
                stderr = html.escape(str(wifi.get("stderr", "")))
                wifi_panel = f"""<section class="panel"><h2>WLAN-Status</h2><p>Status: <strong>{state}</strong></p><pre>{stdout}</pre><pre>{stderr}</pre></section>"""
            else:
                current_wifi = wifi_status()
                wifi_panel = f"""<section class="panel"><h2>WLAN-Status</h2><pre>{html.escape(current_wifi.get("stdout", ""))}</pre><pre>{html.escape(current_wifi.get("stderr", ""))}</pre></section>"""

            config_rows = "".join(f"<tr><th>{html.escape(key)}</th><td>{html.escape(value)}</td></tr>" for key, value in public_config(config).items())
            content = f"""<p class="muted">Richte das System wie bei einem Router ein: erst lokales Setup-Passwort und Hostname. WLAN ist optional, wenn ein Netzwerkkabel verbunden ist.</p>
{net_panel}
{wifi_panel}
<form method="post" action="/setup/save">
  <h2>System</h2>
  <label for="hostname">Hostname</label>
  <input id="hostname" name="hostname" value="{html.escape(config.get("hostname", "autodarts-pi"))}">
  <label for="setup_admin_password">Neues Setup-Passwort</label>
  <input id="setup_admin_password" name="setup_admin_password" type="password" placeholder="leer lassen, wenn unveraendert">
  <h2>WLAN</h2>
  <p class="muted">Leer lassen, wenn du Ethernet verwendest.</p>
  <label for="wifi_ssid">WLAN-Name</label>
  <input id="wifi_ssid" name="wifi_ssid" value="{html.escape(config.get("wifi_ssid", ""))}">
  <label for="wifi_password">WLAN-Passwort</label>
  <input id="wifi_password" name="wifi_password" type="password">
  <label for="wifi_country">Land</label>
  <input id="wifi_country" name="wifi_country" value="{html.escape(config.get("wifi_country", "DE"))}">
  <button type="submit">Speichern</button>
</form>
<form method="post" action="/setup/finish">
  <h2>Setup abschliessen</h2>
  <p class="muted">Das funktioniert mit Netzwerkkabel oder WLAN. Danach startet der Kiosk auf Autodarts Play statt auf diesem Setup.</p>
  <button type="submit">Setup abschliessen</button>
</form>
<section>
  <a class="button" href="/health.json">Systemstatus</a>
  <a class="button" href="/logs/kiosk">Kiosk-Log</a>
  <a class="button" href="https://play.autodarts.io">Autodarts Play</a>
</section>
<section><h2>Aktuelle Konfiguration</h2><table>{config_rows}</table></section>"""
            payload = render_page("Autodarts Pi OS Setup", content).encode("utf-8")
            self.send_response(200)
            self.send_header("Content-Type", "text/html; charset=utf-8")
            self.send_header("Content-Length", str(len(payload)))
            self.end_headers()
            self.wfile.write(payload)
            return

        status = {
            "Runtime": service_state("autodarts-runtime.service"),
            "Watchdog": service_state("autodarts-watchdog.service"),
            "Web panel": service_state("autodarts-webpanel.service"),
        }
        rows = "".join(
            f"<tr><th>{html.escape(key)}</th><td>{html.escape(value)}</td></tr>"
            for key, value in status.items()
        )
        config_rows = "".join(
            f"<tr><th>{html.escape(key)}</th><td>{html.escape(value)}</td></tr>"
            for key, value in public_config(config).items()
        )
        body = f"""<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Autodarts Pi OS</title>
  <style>
    body {{ margin: 0; font-family: system-ui, sans-serif; background: #101412; color: #eef7ef; }}
    main {{ max-width: 960px; margin: 0 auto; padding: 32px 20px; }}
    header {{ display: flex; align-items: center; gap: 18px; margin-bottom: 28px; }}
    img {{ width: 96px; height: 96px; object-fit: contain; }}
    h1 {{ margin: 0; font-size: 32px; }}
    p {{ color: #b8c7bb; }}
    section {{ margin-top: 24px; }}
    table {{ width: 100%; border-collapse: collapse; background: #171d1a; border: 1px solid #2b3830; }}
    th, td {{ text-align: left; padding: 12px 14px; border-bottom: 1px solid #2b3830; }}
    th {{ width: 190px; color: #9ee26d; }}
    a {{ color: #9ee26d; }}
  </style>
</head>
<body>
  <main>
    <header>
      <img src="/splash.png" alt="">
      <div>
        <h1>Autodarts Pi OS</h1>
        <p>{html.escape(socket.gethostname())}</p>
      </div>
    </header>
    <section><h2>Services</h2><table>{rows}</table></section>
    <section><h2>Configuration</h2><table>{config_rows}</table></section>
    <p><a href="/health.json">health.json</a></p>
  </main>
</body>
</html>"""
        payload = body.encode("utf-8")
        self.send_response(200)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.send_header("Content-Length", str(len(payload)))
        self.end_headers()
        self.wfile.write(payload)

    def log_message(self, format, *args):
        return


if __name__ == "__main__":
    config = read_config()
    port = int(config.get("webpanel_port", PORT))
    HTTPServer(("0.0.0.0", port), Handler).serve_forever()
