def kiosk_shell_url(config, request_host, target):
    target = (target or "manager").strip().lower()
    if target in {"play", "autodarts-play"}:
        return config.get("play_url", "https://play.autodarts.io"), "Autodarts Play"
    if target in {"config", "camera", "cameras", "kameras", "kamera-setup"}:
        autodarts_url = detect_autodarts_url(config)
        if autodarts_url:
            host = (request_host or "").split(",", 1)[0].strip()
            if host.startswith("127.0.0.1") or host.startswith("localhost"):
                return append_url_path(autodarts_url, "/config"), "Kamera-Setup"
            return external_autodarts_url(request_host, "/config"), "Kamera-Setup"
        return external_autodarts_url(request_host, "/config"), "Kamera-Setup"
    if target in {"setup", "network"}:
        return "/setup", "Netzwerk-Setup"
    if target in {"admin"}:
        return "/admin", "Admin"
    if target in {"home", "kiosk"}:
        return "/kiosk", "Autodarts Pi OS"
    autodarts_url = detect_autodarts_url(config)
    if autodarts_url:
        host = (request_host or "").split(",", 1)[0].strip()
        if host.startswith("127.0.0.1") or host.startswith("localhost"):
            return autodarts_url, "Autodarts Manager"
        return external_autodarts_url(request_host), "Autodarts Manager"
    return external_autodarts_url(request_host), "Autodarts Manager"


def render_kiosk_shell(config, request_host, target):
    frame_url, label = kiosk_shell_url(config, request_host, target)
    return f"""<!doctype html>
<html lang="de">
