CONFIG = Path("/etc/autodarts-pi-os/config.toml")
DEFAULT_CONFIG = Path("/usr/share/autodarts-pi-os/default-config.toml")
SPLASH = Path("/usr/share/autodarts-pi-os/splash.png")
KOFI_LOGO = Path("/usr/share/autodarts-pi-os/kofi-logo.webp")
STATUS_FILE = Path("/var/lib/autodarts-pi-os/setup-status.json")
SETUP_STATE = Path("/var/lib/autodarts-pi-os/setup.state")
WIFI_APPLY_REQUEST = Path("/var/lib/autodarts-pi-os/wifi-apply.request")
WIFI_CREDENTIALS = Path("/var/lib/autodarts-pi-os/wifi-credentials.json")
KIOSK_LOG = Path("/var/log/autodarts-kiosk.log")
NETWORK_LOG = Path("/var/log/autodarts-network.log")
INSTALL_LOG = Path("/var/log/autodarts-install.log")
FIRSTBOOT_LOG = Path("/var/log/autodarts-firstboot.log")
INSTALL_MARKER = Path("/var/lib/autodarts-pi-os/autodarts-install.done")
SESSION_FILE = Path("/var/lib/autodarts-pi-os/webpanel-session")
CSRF_FILE = Path("/var/lib/autodarts-pi-os/webpanel-csrf")
LOGIN_ATTEMPTS_FILE = Path("/var/lib/autodarts-pi-os/login-attempts.json")
PORT = 80
DEFAULT_SETUP_PASSWORD = "autodarts"
PASSWORD_HASH_PREFIX = "pbkdf2_sha256"
LOGIN_MAX_ATTEMPTS = 5
LOGIN_LOCK_SECONDS = 120
SESSION_MAX_AGE_SECONDS = 12 * 60 * 60


def secure_file(path, mode=0o640):
    try:
        path.chmod(mode)
    except OSError:
        pass
    try:
        import grp

        os.chown(path, 0, grp.getgrnam("autodarts").gr_gid)
    except (KeyError, OSError):
        pass


def read_config():
    if not CONFIG.exists():
        return {}
    values = {}
    for line in CONFIG.read_text(encoding="utf-8").splitlines():
        if "=" not in line or line.strip().startswith("#"):
            continue
        key, value = line.split("=", 1)
        values[key.strip()] = value.strip().strip('"')
    return values


def write_config(values):
    lines = []
    for key, value in values.items():
        if isinstance(value, bool):
            rendered = "true" if value else "false"
        elif str(value).lower() in {"true", "false"}:
            rendered = str(value).lower()
        elif str(value).isdigit():
            rendered = str(value)
        else:
            escaped = str(value).replace("\\", "\\\\").replace('"', '\\"')
            rendered = f'"{escaped}"'
        lines.append(f"{key} = {rendered}")
    CONFIG.write_text("\n".join(lines) + "\n", encoding="utf-8")
    secure_file(CONFIG)


def password_hash(password):
    salt = secrets.token_hex(16)
    iterations = 210000
    digest = hashlib.pbkdf2_hmac("sha256", password.encode("utf-8"), salt.encode("ascii"), iterations)
    return f"{PASSWORD_HASH_PREFIX}${iterations}${salt}${digest.hex()}"


def password_matches(password, config):
    stored_hash = config.get("setup_admin_password_hash", "")
    if stored_hash.startswith(f"{PASSWORD_HASH_PREFIX}$"):
        try:
            _, iterations, salt, expected = stored_hash.split("$", 3)
            digest = hashlib.pbkdf2_hmac("sha256", password.encode("utf-8"), salt.encode("ascii"), int(iterations))
            return secrets.compare_digest(digest.hex(), expected)
        except (ValueError, TypeError):
            return False
    return secrets.compare_digest(password, config.get("setup_admin_password", DEFAULT_SETUP_PASSWORD))


def sanitize_hostname(value):
    value = str(value or "").strip().lower()
    value = re.sub(r"[^a-z0-9-]+", "-", value)
    value = re.sub(r"-+", "-", value).strip("-")
    if not value:
        return "autodarts-pi"
    return value[:63].strip("-") or "autodarts-pi"


def ensure_hosts_entry(hostname):
    if not hostname:
        return
    current = Path("/etc/hosts").read_text(encoding="utf-8", errors="replace") if Path("/etc/hosts").exists() else ""
    lines = current.splitlines()
    replaced = False
    rendered = f"127.0.1.1\t{hostname}"
    output = []
    for line in lines:
        if re.match(r"^\s*127\.0\.1\.1\s+", line):
            if not replaced:
                output.append(rendered)
                replaced = True
            continue
        output.append(line)
    if not replaced:
        output.append(rendered)
    Path("/etc/hosts").write_text("\n".join(output) + "\n", encoding="utf-8")


def public_config(values):
    redacted = {}
    for key, value in values.items():
        if "password" in key:
            redacted[key] = "********" if value else ""
        else:
            redacted[key] = value
    return redacted


def session_token():
    SESSION_FILE.parent.mkdir(parents=True, exist_ok=True)
    if not SESSION_FILE.exists():
        SESSION_FILE.write_text(secrets.token_urlsafe(32), encoding="utf-8")
        SESSION_FILE.chmod(0o600)
    return SESSION_FILE.read_text(encoding="utf-8").strip()


def reset_session_token():
    SESSION_FILE.parent.mkdir(parents=True, exist_ok=True)
    SESSION_FILE.write_text(secrets.token_urlsafe(32), encoding="utf-8")
    SESSION_FILE.chmod(0o600)
    reset_csrf_token()


def session_active():
    if not SESSION_FILE.exists():
        return False
    try:
        return time.time() - SESSION_FILE.stat().st_mtime <= SESSION_MAX_AGE_SECONDS
    except OSError:
        return False


def csrf_token():
    CSRF_FILE.parent.mkdir(parents=True, exist_ok=True)
    if not CSRF_FILE.exists():
        CSRF_FILE.write_text(secrets.token_urlsafe(32), encoding="utf-8")
        CSRF_FILE.chmod(0o600)
    return CSRF_FILE.read_text(encoding="utf-8").strip()


def reset_csrf_token():
    CSRF_FILE.parent.mkdir(parents=True, exist_ok=True)
    CSRF_FILE.write_text(secrets.token_urlsafe(32), encoding="utf-8")
    CSRF_FILE.chmod(0o600)


def csrf_input():
    return f'<input type="hidden" name="csrf_token" value="{html.escape(csrf_token())}">'


def csrf_valid(data):
    return secrets.compare_digest(data.get("csrf_token", [""])[0], csrf_token())


def service_state(name):
    try:
        result = subprocess.run(
            ["systemctl", "is-active", name],
            text=True,
            encoding="utf-8",
            errors="replace",
            capture_output=True,
            timeout=1,
            check=False,
        )
        return result.stdout.strip() or result.stderr.strip() or "unknown"
    except Exception as exc:
        return f"unavailable: {exc}"


def run_command(command):
    try:
        result = subprocess.run(
            command,
            text=True,
            encoding="utf-8",
            errors="replace",
            capture_output=True,
            timeout=75,
            check=False,
        )
        return result.returncode, result.stdout.strip(), result.stderr.strip()
    except Exception as exc:
        return 1, "", str(exc)


def read_status():
    if not STATUS_FILE.exists():
        return {}
    try:
        return json.loads(STATUS_FILE.read_text(encoding="utf-8"))
    except Exception:
        return {}


def write_status(values):
    STATUS_FILE.parent.mkdir(parents=True, exist_ok=True)
    STATUS_FILE.write_text(json.dumps(values, indent=2), encoding="utf-8")
    secure_file(STATUS_FILE)


def read_setup_state():
    if not SETUP_STATE.exists():
        return "factory"
    value = SETUP_STATE.read_text(encoding="utf-8").strip()
    return value or "factory"


def write_setup_state(value):
    SETUP_STATE.parent.mkdir(parents=True, exist_ok=True)
    SETUP_STATE.write_text(value + "\n", encoding="utf-8")


def read_wifi_credentials():
    if not WIFI_CREDENTIALS.exists():
        return {}
    try:
        return json.loads(WIFI_CREDENTIALS.read_text(encoding="utf-8"))
    except Exception:
        return {}


def write_wifi_credentials(ssid, password, country):
    WIFI_CREDENTIALS.parent.mkdir(parents=True, exist_ok=True)
    payload = {
        "ssid": ssid,
        "password": password,
        "country": country,
        "password_saved": bool(password),
    }
    WIFI_CREDENTIALS.write_text(json.dumps(payload, indent=2), encoding="utf-8")
    WIFI_CREDENTIALS.chmod(0o600)


def read_login_attempts():
    if not LOGIN_ATTEMPTS_FILE.exists():
        return {}
    try:
        return json.loads(LOGIN_ATTEMPTS_FILE.read_text(encoding="utf-8"))
    except Exception:
        return {}


def write_login_attempts(values):
    LOGIN_ATTEMPTS_FILE.parent.mkdir(parents=True, exist_ok=True)
    LOGIN_ATTEMPTS_FILE.write_text(json.dumps(values), encoding="utf-8")
    LOGIN_ATTEMPTS_FILE.chmod(0o600)


def login_key(handler):
    try:
        return str(ipaddress.ip_address(handler.client_address[0]))
    except ValueError:
        return "unknown"


def login_locked(handler):
    attempts = read_login_attempts()
    entry = attempts.get(login_key(handler), {})
    locked_until = float(entry.get("locked_until", 0) or 0)
    return time.time() < locked_until


def record_login_success(handler):
    attempts = read_login_attempts()
    attempts.pop(login_key(handler), None)
    write_login_attempts(attempts)


def record_login_failure(handler):
    attempts = read_login_attempts()
    key = login_key(handler)
    entry = attempts.get(key, {})
    count = int(entry.get("count", 0) or 0) + 1
    entry = {"count": count, "last_failure": time.time()}
    if count >= LOGIN_MAX_ATTEMPTS:
        entry["locked_until"] = time.time() + LOGIN_LOCK_SECONDS
        entry["count"] = 0
    attempts[key] = entry
    write_login_attempts(attempts)


def mark_setup_configured(config, status, message):
    config["setup_mode"] = "false"
    write_config(config)
    write_setup_state("configured")
    status["finish"] = {"state": "ok", "message": message}
    write_status(status)


def wifi_status():
    code, stdout, stderr = run_command(["nmcli", "-t", "-f", "DEVICE,TYPE,STATE,CONNECTION", "device"])
    return {
        "returncode": code,
        "stdout": stdout,
        "stderr": stderr,
    }


def network_status():
    device_code, device_stdout, device_stderr = run_command(["nmcli", "-t", "-f", "DEVICE,TYPE,STATE,CONNECTION", "device"])
    general_code, general_stdout, general_stderr = run_command(["nmcli", "-t", "-f", "STATE,CONNECTIVITY", "general"])
    ip_code, ip_stdout, ip_stderr = run_command(["hostname", "-I"])
    assigned_ips = [ip for ip in ip_stdout.split() if ip and not ip.startswith("127.")]
    primary_ip = assigned_ips[0] if assigned_ips else ""
    ethernet_connected = any(
        line.split(":")[1:3] == ["ethernet", "connected"]
        for line in device_stdout.splitlines()
        if len(line.split(":")) >= 3
    )
    wifi_connected = any(
        len(line.split(":")) >= 4
        and line.split(":")[1:3] == ["wifi", "connected"]
        and line.split(":")[3] != "Autodarts-Setup"
        for line in device_stdout.splitlines()
    )
    setup_hotspot_active = any(
        len(line.split(":")) >= 4 and line.split(":")[3] == "Autodarts-Setup"
        for line in device_stdout.splitlines()
    )
    return {
        "online": ethernet_connected or wifi_connected,
        "ethernet_connected": ethernet_connected,
        "wifi_connected": wifi_connected,
        "setup_hotspot_active": setup_hotspot_active,
        "devices": {
            "returncode": device_code,
            "stdout": device_stdout,
            "stderr": device_stderr,
        },
        "general": {
            "returncode": general_code,
            "stdout": general_stdout,
            "stderr": general_stderr,
        },
        "ip_addresses": {
            "returncode": ip_code,
            "stdout": ip_stdout,
            "stderr": ip_stderr,
        },
        "assigned_ips": assigned_ips,
        "primary_ip": primary_ip,
    }


def tail_file(path, fallback, limit=8000):
    if not path.exists():
        return fallback
    return path.read_text(encoding="utf-8", errors="replace")[-limit:]


def url_reachable(url):
    if not url:
        return False
    try:
        req = urlrequest.Request(url, method="GET", headers={"User-Agent": "AutodartsPiOS/1.0"})
        with urlrequest.urlopen(req, timeout=2) as response:
            return 200 <= response.status < 500
    except urlerror.HTTPError as exc:
        return 200 <= exc.code < 500
    except (OSError, urlerror.URLError, ValueError):
        return False


def autodarts_url_candidates(config):
    candidates = [
        config.get("autodarts_config_url", ""),
        config.get("autodarts_local_url", ""),
        "http://localhost:3180",
        "http://127.0.0.1:3180",
        "http://localhost:8080",
        "http://127.0.0.1:8080",
    ]
    seen = set()
    for candidate in candidates:
        candidate = str(candidate).strip()
        if candidate and candidate not in seen:
            seen.add(candidate)
            yield candidate


def detect_autodarts_url(config):
    for candidate in autodarts_url_candidates(config):
        if url_reachable(candidate):
            return candidate
    return ""


def external_autodarts_url(request_host, path=""):
    host = (request_host or "").split(",", 1)[0].strip()
    if not host:
        host = socket.gethostname() or "autodarts-pi"
    if host.startswith("[") and "]" in host:
        hostname = host.split("]", 1)[0] + "]"
    else:
        hostname = host.split(":", 1)[0]
    if path and not path.startswith("/"):
        path = "/" + path
    return f"http://{hostname}:3180{path}"


def append_url_path(url, path):
    if not path:
        return url
    if not path.startswith("/"):
        path = "/" + path
    return url.rstrip("/") + path


def is_authenticated(handler):
    header = handler.headers.get("Cookie", "")
    jar = cookies.SimpleCookie()
    jar.load(header)
    return session_active() and jar.get("autodarts_setup") and jar["autodarts_setup"].value == session_token()


def is_default_setup_password(config):
    return not config.get("setup_admin_password_hash") and config.get("setup_admin_password", DEFAULT_SETUP_PASSWORD) == DEFAULT_SETUP_PASSWORD


def client_allowed(handler, config):
    if str(config.get("allow_public_webpanel", "false")).lower() == "true":
        return True
    try:
        addr = ipaddress.ip_address(handler.client_address[0])
    except ValueError:
        return False
    return addr.is_loopback or addr.is_private or addr.is_link_local


def deny_forbidden(handler):
    body = b"Autodarts Pi OS web panel is only available from local or private networks.\n"
    handler.send_response(403)
    handler.send_header("Content-Type", "text/plain; charset=utf-8")
    handler.send_header("Content-Length", str(len(body)))
    handler.end_headers()
    handler.wfile.write(body)


def login_notice(handler):
    query = parse_qs(urlparse(handler.path).query, keep_blank_values=True)
    state = query.get("login", [""])[0]
    if state == "locked":
        return """<div class="panel danger"><p><strong>Zu viele Fehlversuche.</strong> Bitte warte kurz und versuche es dann erneut.</p></div>"""
    if state == "failed":
        return """<div class="panel danger"><p><strong>Login fehlgeschlagen.</strong> Bitte pruefe das Passwort.</p></div>"""
    return ""


