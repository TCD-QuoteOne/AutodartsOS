#!/usr/bin/env bash
set -euo pipefail

CONFIG_FILE="/etc/autodarts-pi-os/config.toml"
STATE_DIR="/var/lib/autodarts-pi-os"
MARKER="$STATE_DIR/autodarts-install.done"
LOG_FILE="/var/log/autodarts-install.log"
DEFAULT_INSTALLER_URL="https://get.autodarts.io"
LOCAL_INSTALLER="/usr/share/autodarts-pi-os/autodarts-installer.sh"
LOCAL_INSTALLER_SHA="${LOCAL_INSTALLER}.sha256"

config_string() {
  local key="$1"
  awk -F '"' -v key="$key" '$0 ~ "^" key "[[:space:]]*=" {print $2; exit}' "$CONFIG_FILE" 2>/dev/null || true
}

config_bool() {
  local key="$1"
  awk -F '=' -v key="$key" '$0 ~ "^" key "[[:space:]]*=" {gsub(/[[:space:]]/, "", $2); print $2; exit}' "$CONFIG_FILE" 2>/dev/null || true
}

mkdir -p "$STATE_DIR"
touch "$LOG_FILE"

if [[ "$(config_bool autodarts_install_enabled)" == "false" ]]; then
  echo "Autodarts installation disabled by config." | tee -a "$LOG_FILE"
  touch "$MARKER"
  exit 0
fi

INSTALLER_URL="$(config_string autodarts_installer_url)"
INSTALLER_URL="${INSTALLER_URL:-$DEFAULT_INSTALLER_URL}"
VERSION="$(config_string autodarts_version)"
VERSION="${VERSION:-latest}"
HOST="$(printf '%s\n' "$INSTALLER_URL" | sed -E 's#^[a-zA-Z]+://([^/:]+).*#\1#')"
INSTALLER="/tmp/autodarts-installer.sh"
TARGET_USER="autodarts"
TARGET_HOME="/home/autodarts"
REMOTE_FALLBACK="$(config_bool autodarts_installer_remote_fallback)"
REMOTE_FALLBACK="${REMOTE_FALLBACK:-false}"
REMOTE_SHA256="$(config_string autodarts_installer_sha256)"

network_online() {
  nmcli -t -f STATE general status 2>/dev/null | grep -qx connected || return 1
  getent hosts "$HOST" >/dev/null 2>&1
}

while ! network_online; do
  echo "Waiting for Ethernet or WiFi before installing Autodarts..." | tee -a "$LOG_FILE"
  sleep 5
done

verify_installer_file() {
  local installer="$1"
  local expected_sha="$2"
  if [[ -z "$expected_sha" ]]; then
    echo "No SHA256 checksum available for installer: $installer" | tee -a "$LOG_FILE"
    return 1
  fi
  printf '%s  %s\n' "$expected_sha" "$installer" | sha256sum -c - >/dev/null
}

if [[ -f "$LOCAL_INSTALLER" ]]; then
  echo "Using bundled Autodarts installer from $LOCAL_INSTALLER" | tee -a "$LOG_FILE"
  if [[ ! -f "$LOCAL_INSTALLER_SHA" ]]; then
    echo "Bundled installer checksum is missing: $LOCAL_INSTALLER_SHA" | tee -a "$LOG_FILE"
    exit 1
  fi
  BUNDLED_SHA="$(awk '{print $1; exit}' "$LOCAL_INSTALLER_SHA")"
  verify_installer_file "$LOCAL_INSTALLER" "$BUNDLED_SHA" || {
    echo "Bundled Autodarts installer checksum verification failed." | tee -a "$LOG_FILE"
    exit 1
  }
  cp "$LOCAL_INSTALLER" "$INSTALLER"
elif [[ "$REMOTE_FALLBACK" == "true" || "$REMOTE_FALLBACK" == "1" ]]; then
  echo "Downloading Autodarts installer from $INSTALLER_URL" | tee -a "$LOG_FILE"
  curl --fail --location --silent --show-error --retry 10 --retry-delay 5 "$INSTALLER_URL" --output "$INSTALLER"
  verify_installer_file "$INSTALLER" "$REMOTE_SHA256" || {
    echo "Remote Autodarts installer checksum verification failed." | tee -a "$LOG_FILE"
    exit 1
  }
else
  echo "No bundled Autodarts installer found and remote fallback is disabled." | tee -a "$LOG_FILE"
  echo "Build the release with BUNDLE_AUTODARTS_INSTALLER=true." | tee -a "$LOG_FILE"
  exit 1
fi
chmod +x "$INSTALLER"
install -d -m 0755 -o "$TARGET_USER" -g "$TARGET_USER" "$TARGET_HOME"
install -d -m 0700 -o "$TARGET_USER" -g "$TARGET_USER" "$TARGET_HOME/.local" "$TARGET_HOME/.config" "$TARGET_HOME/.cache"

run_installer() {
  env \
    HOME="$TARGET_HOME" \
    USER="$TARGET_USER" \
    LOGNAME="$TARGET_USER" \
    SUDO_USER="$TARGET_USER" \
    SUDO_UID="$(id -u "$TARGET_USER")" \
    SUDO_GID="$(id -g "$TARGET_USER")" \
    XDG_CONFIG_HOME="$TARGET_HOME/.config" \
    XDG_CACHE_HOME="$TARGET_HOME/.cache" \
    XDG_DATA_HOME="$TARGET_HOME/.local/share" \
    bash "$@"
}

if [[ "$VERSION" == "latest" ]]; then
  echo "Installing latest Autodarts version." | tee -a "$LOG_FILE"
  run_installer "$INSTALLER" 2>&1 | tee -a "$LOG_FILE"
else
  echo "Installing Autodarts version $VERSION." | tee -a "$LOG_FILE"
  run_installer "$INSTALLER" "$VERSION" 2>&1 | tee -a "$LOG_FILE"
fi

chown -R "$TARGET_USER:$TARGET_USER" "$TARGET_HOME/.local" "$TARGET_HOME/.config" "$TARGET_HOME/.cache" || true
touch "$MARKER"
echo "Autodarts installation completed." | tee -a "$LOG_FILE"
