#!/usr/bin/env bash
set -euo pipefail

CONFIG_FILE="/etc/autodarts-pi-os/config.toml"
LOG_FILE="/var/log/autodarts-network.log"
HOTSPOT_NAME="Autodarts-Setup"
WIFI_CLIENT_NAME="Autodarts-WiFi"
SETUP_STATE_FILE="/var/lib/autodarts-pi-os/setup.state"
STATUS_FILE="/var/lib/autodarts-pi-os/setup-status.json"
WIFI_APPLY_REQUEST="/var/lib/autodarts-pi-os/wifi-apply.request"
WIFI_CREDENTIALS="/var/lib/autodarts-pi-os/wifi-credentials.json"

exec >>"$LOG_FILE" 2>&1

config_string() {
  local key="$1"
  awk -F '"' -v key="$key" '$0 ~ "^" key "[[:space:]]*=" {print $2; exit}' "$CONFIG_FILE" 2>/dev/null || true
}

config_bool() {
  local key="$1"
  awk -F '=' -v key="$key" '$0 ~ "^" key "[[:space:]]*=" {gsub(/[[:space:]]/, "", $2); print $2; exit}' "$CONFIG_FILE" 2>/dev/null || true
}

config_bool_default() {
  local key="$1"
  local fallback="$2"
  local value
  value="$(config_bool "$key")"
  echo "${value:-$fallback}"
}

credential_string() {
  local key="$1"
  if [[ -f "$WIFI_CREDENTIALS" ]] && command -v python3 >/dev/null 2>&1; then
    python3 - "$WIFI_CREDENTIALS" "$key" <<'PY'
import json
import sys
path, key = sys.argv[1], sys.argv[2]
try:
    with open(path, encoding="utf-8") as handle:
        value = json.load(handle).get(key, "")
except Exception:
    value = ""
print(value or "")
PY
  fi
}

set_config_bool() {
  local key="$1"
  local value="$2"
  if grep -qE "^${key}[[:space:]]*=" "$CONFIG_FILE" 2>/dev/null; then
    sed -i -E "s|^${key}[[:space:]]*=.*|${key} = ${value}|" "$CONFIG_FILE"
  else
    printf '%s = %s\n' "$key" "$value" >> "$CONFIG_FILE"
  fi
}

set_config_string() {
  local key="$1"
  local value="$2"
  local escaped
  escaped="$(printf '%s' "$value" | sed 's/\\/\\\\/g; s/"/\\"/g')"
  if grep -qE "^${key}[[:space:]]*=" "$CONFIG_FILE" 2>/dev/null; then
    sed -i -E "s|^${key}[[:space:]]*=.*|${key} = \"${escaped}\"|" "$CONFIG_FILE"
  else
    printf '%s = "%s"\n' "$key" "$escaped" >> "$CONFIG_FILE"
  fi
}

ensure_setup_hotspot_password() {
  local password
  password="$(config_string setup_hotspot_password)"
  printf '%s' "${password:-autodarts}"
}

mark_configured() {
  mkdir -p "$(dirname "$SETUP_STATE_FILE")"
  set_config_bool setup_mode false
  echo "configured" > "$SETUP_STATE_FILE"
}

write_network_status() {
  local message="$1"
  local assigned_ip
  assigned_ip="$(hostname -I 2>/dev/null | awk '{print $1}')"
  mkdir -p "$(dirname "$STATUS_FILE")"
  cat > "$STATUS_FILE" <<EOF
{
  "network": {
    "state": "ok",
    "message": "$(json_string "$message")",
    "assigned_ip": "$(json_string "$assigned_ip")"
  }
}
EOF
}

wifi_device() {
  nmcli -t -f DEVICE,TYPE device status | awk -F ':' '$2 == "wifi" {print $1; exit}'
}

connected_network() {
  nmcli -t -f DEVICE,TYPE,STATE,CONNECTION device status | awk -F ':' '
    $3 == "connected" && $4 != "Autodarts-Setup" && ($2 == "ethernet" || $2 == "wifi") { found=1 }
    END { exit found ? 0 : 1 }
  '
}

connected_wifi() {
  nmcli -t -f DEVICE,TYPE,STATE,CONNECTION device status | awk -F ':' '
    $3 == "connected" && $4 != "Autodarts-Setup" && $2 == "wifi" { found=1 }
    END { exit found ? 0 : 1 }
  '
}

setup_state() {
  if [[ -f "$SETUP_STATE_FILE" ]]; then
    tr -d '[:space:]' < "$SETUP_STATE_FILE"
  else
    echo "factory"
  fi
}

hotspot_active() {
  nmcli -t -f NAME,TYPE,DEVICE connection show --active | awk -F ':' '$1 == "Autodarts-Setup" { found=1 } END { exit found ? 0 : 1 }'
}

stop_hotspot() {
  if hotspot_active; then
    echo "$(date -Is) stopping setup hotspot"
    nmcli connection down "$HOTSPOT_NAME" || true
  fi
}

ensure_hotspot() {
  local ssid password address device
  ssid="$(config_string setup_hotspot_ssid)"
  password="$(ensure_setup_hotspot_password)"
  address="$(config_string setup_hotspot_address)"
  ssid="${ssid:-Autodarts-Setup}"
  address="${address:-10.42.0.1/24}"
  device="$(wifi_device)"

  if [[ -z "$device" ]]; then
    echo "$(date -Is) no WiFi device available for setup hotspot"
    return 0
  fi

  rfkill unblock wifi || true
  nmcli radio wifi on || true

  if ! nmcli connection show "$HOTSPOT_NAME" >/dev/null 2>&1; then
    echo "$(date -Is) creating setup hotspot on $device"
    nmcli connection add type wifi ifname "$device" con-name "$HOTSPOT_NAME" ssid "$ssid"
  fi

  nmcli connection modify "$HOTSPOT_NAME" \
    802-11-wireless.mode ap \
    802-11-wireless.ssid "$ssid" \
    ipv4.method shared \
    ipv4.addresses "$address" \
    ipv6.method disabled \
    connection.autoconnect no \
    wifi-sec.key-mgmt wpa-psk \
    wifi-sec.psk "$password"

  if ! hotspot_active; then
    echo "$(date -Is) starting setup hotspot: $ssid"
    nmcli connection up "$HOTSPOT_NAME" || true
  fi
}

json_string() {
  printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g; s/\r//g' | tr '\n' ' '
}

write_wifi_status() {
  local state="$1"
  local message="$2"
  local ssid="${3:-}"
  local stdout="${4:-}"
  local stderr="${5:-}"
  local assigned_ip="${6:-}"

  mkdir -p "$(dirname "$STATUS_FILE")"
  cat > "$STATUS_FILE" <<EOF
{
  "wifi": {
    "state": "$(json_string "$state")",
    "message": "$(json_string "$message")",
    "ssid": "$(json_string "$ssid")",
    "assigned_ip": "$(json_string "$assigned_ip")",
    "stdout": "$(json_string "$stdout")",
    "stderr": "$(json_string "$stderr")"
  }
}
EOF
}

apply_pending_wifi() {
  local device ssid password country tmp_stdout tmp_stderr code rc assigned_ip

  [[ -f "$WIFI_APPLY_REQUEST" ]] || return 1

  ssid="$(credential_string ssid)"
  password="$(credential_string password)"
  country="$(credential_string country)"
  ssid="${ssid:-$(config_string wifi_ssid)}"
  password="${password:-$(config_string wifi_password)}"
  country="${country:-$(config_string wifi_country)}"
  country="${country:-DE}"

  if [[ -z "$ssid" ]]; then
    echo "$(date -Is) WiFi apply requested without SSID"
    rm -f "$WIFI_APPLY_REQUEST"
    write_wifi_status "failed" "Es wurde kein WLAN-Name gespeichert."
    return 0
  fi

  if [[ -z "$password" ]]; then
    echo "$(date -Is) WiFi apply requested without password for SSID '$ssid'"
    rm -f "$WIFI_APPLY_REQUEST"
    write_wifi_status "failed" "Es wurde kein WLAN-Passwort gespeichert. Trage das Passwort erneut ein und speichere noch einmal." "$ssid"
    return 0
  fi

  device="$(wifi_device)"
  if [[ -z "$device" ]]; then
    echo "$(date -Is) WiFi apply requested, but no WiFi device exists"
    rm -f "$WIFI_APPLY_REQUEST"
    write_wifi_status "failed" "Es wurde kein WLAN-Geraet gefunden." "$ssid"
    return 0
  fi

  echo "$(date -Is) applying pending WiFi credentials for SSID '$ssid'"
  write_wifi_status "running" "Der Setup-Hotspot wird kurz deaktiviert und das WLAN wird getestet." "$ssid"
  stop_hotspot
  sleep 3
  rfkill unblock wifi || true
  nmcli radio wifi on || true
  nmcli device set "$device" managed yes || true
  nmcli device disconnect "$device" >/dev/null 2>&1 || true
  nmcli general hostname "$(config_string hostname || true)" >/dev/null 2>&1 || true
  iw reg set "$country" >/dev/null 2>&1 || true
  nmcli device wifi rescan ifname "$device" >/dev/null 2>&1 || nmcli device wifi rescan >/dev/null 2>&1 || true
  sleep 3

  tmp_stdout="$(mktemp)"
  tmp_stderr="$(mktemp)"
  nmcli connection delete "$WIFI_CLIENT_NAME" >/dev/null 2>&1 || true
  set +e
  nmcli connection add type wifi ifname "$device" con-name "$WIFI_CLIENT_NAME" ssid "$ssid" >"$tmp_stdout" 2>"$tmp_stderr"
  code=$?
  nmcli connection modify "$WIFI_CLIENT_NAME" wifi-sec.key-mgmt wpa-psk wifi-sec.psk "$password" >>"$tmp_stdout" 2>>"$tmp_stderr"
  rc=$?
  [[ "$code" -eq 0 ]] && code="$rc"
  if [[ "$code" -eq 0 ]]; then
    nmcli connection modify "$WIFI_CLIENT_NAME" connection.autoconnect yes ipv4.method auto ipv6.method auto >>"$tmp_stdout" 2>>"$tmp_stderr"
    code=$?
  fi
  if [[ "$code" -eq 0 ]]; then
    nmcli --wait 75 connection up "$WIFI_CLIENT_NAME" ifname "$device" >>"$tmp_stdout" 2>>"$tmp_stderr"
    code=$?
  fi
  set -e

  if [[ "$code" -eq 0 ]]; then
    assigned_ip="$(hostname -I 2>/dev/null | awk '{print $1}')"
    echo "$(date -Is) WiFi connected to '$ssid'"
    mark_configured
    stop_hotspot
    write_wifi_status "ok" "WLAN wurde verbunden. Das System startet jetzt neu. Verbinde dein Handy danach mit demselben Netzwerk und oeffne http://autodarts-pi.local oder die angezeigte IP-Adresse." "$ssid" "$(cat "$tmp_stdout")" "$(cat "$tmp_stderr")" "$assigned_ip"
    rm -f "$tmp_stdout" "$tmp_stderr" "$WIFI_APPLY_REQUEST"
    if [[ "$(config_bool_default reboot_after_wifi true)" != "false" ]]; then
      echo "$(date -Is) rebooting after successful WiFi handoff"
      sync || true
      systemctl reboot --no-wall || reboot
    fi
    return 0
  else
    echo "$(date -Is) WiFi connection failed for '$ssid' with code $code"
    write_wifi_status "failed" "WLAN konnte nicht verbunden werden. Pruefe WLAN-Name und Passwort. Der Setup-Hotspot wird wieder gestartet." "$ssid" "$(cat "$tmp_stdout")" "$(cat "$tmp_stderr")"
    nmcli connection down "$WIFI_CLIENT_NAME" >/dev/null 2>&1 || true
    nmcli connection delete "$WIFI_CLIENT_NAME" >/dev/null 2>&1 || true
  fi

  rm -f "$tmp_stdout" "$tmp_stderr" "$WIFI_APPLY_REQUEST"
  return 0
}

while true; do
  state="$(setup_state)"
  apply_pending_wifi || true

  if [[ "$(config_bool setup_hotspot_enabled)" == "false" ]]; then
    stop_hotspot
  elif [[ "$state" == "configured" ]]; then
    stop_hotspot
  elif [[ "$state" == "factory" ]] && connected_network; then
    echo "$(date -Is) factory setup completed by existing network connection"
    mark_configured
    write_network_status "Netzwerk wurde bereits vorkonfiguriert oder per Ethernet verbunden. Der Setup-Hotspot wird nicht gestartet."
    stop_hotspot
  elif connected_wifi; then
    stop_hotspot
  elif [[ "$state" == "factory" || "$state" == "recovery" ]]; then
    ensure_hotspot
  else
    ensure_hotspot
  fi
  sleep 15
done
