#!/usr/bin/env bash
set -euo pipefail

URL="${1:-https://play.autodarts.io}"
echo "Starting kiosk session for $URL"

if [[ -z "${AUTODARTS_DBUS_SESSION:-}" ]] && command -v dbus-run-session >/dev/null 2>&1; then
  export AUTODARTS_DBUS_SESSION=1
  exec dbus-run-session -- "$0" "$URL"
fi

xset s off || true
xset -dpms || true
xset s noblank || true
unclutter -idle 1 -root >/dev/null 2>&1 &
openbox >/dev/null 2>&1 &

BROWSER="$(command -v chromium-browser || command -v chromium || true)"
if [[ -z "$BROWSER" ]]; then
  echo "Chromium is not installed."
  exit 20
fi

CHROME_USER_DIR="$HOME/.config/chromium-kiosk"
CHROME_CACHE_DIR="$HOME/.cache/chromium-kiosk"
mkdir -p "$CHROME_USER_DIR" "$CHROME_CACHE_DIR"

while true; do
  "$BROWSER" \
    --kiosk "$URL" \
    --user-data-dir="$CHROME_USER_DIR" \
    --disk-cache-dir="$CHROME_CACHE_DIR" \
    --no-first-run \
    --disable-infobars \
    --disable-session-crashed-bubble \
    --disable-features=TranslateUI \
    --ozone-platform=x11 \
    --autoplay-policy=no-user-gesture-required \
    --noerrdialogs \
    --check-for-update-interval=31536000 \
    --start-maximized
  echo "Chromium exited with code $?. Restarting in 5 seconds."
  sleep 5
done
