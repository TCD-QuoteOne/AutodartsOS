#!/usr/bin/env bash
set -euo pipefail

echo "Status:"
printf "  Weboberflaeche: "
systemctl is-active --quiet autodarts-webpanel.service && echo "aktiv" || echo "nicht aktiv"
printf "  Netzwerkdienst: "
systemctl is-active --quiet autodarts-network.service && echo "aktiv" || echo "nicht aktiv"
printf "  NetworkManager: "
systemctl is-active --quiet NetworkManager.service && echo "aktiv" || echo "nicht aktiv"
printf "  Setup-Hotspot: "
nmcli -t -f NAME connection show --active 2>/dev/null | grep -qx "Autodarts-Setup" && echo "aktiv" || echo "nicht aktiv"
echo
echo "Adressen:"
hostname -I 2>/dev/null | sed 's/^/  /' || true
echo
echo "Setup-Adressen:"
echo "  http://10.42.0.1"
echo "  http://auto.setup.go"
echo "  http://autodarts-pi.local"
