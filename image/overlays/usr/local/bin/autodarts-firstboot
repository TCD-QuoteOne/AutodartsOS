#!/usr/bin/env bash
set -euo pipefail

STATE_DIR="/var/lib/autodarts-pi-os"
CONFIG_DIR="/etc/autodarts-pi-os"
SEED_CONFIG="/boot/firmware/autodarts-config.toml"
CONFIG_FILE="$CONFIG_DIR/config.toml"
SETUP_STATE="$STATE_DIR/setup.state"
STATUS_FILE="$STATE_DIR/setup-status.json"
FIRSTBOOT_LOG="/var/log/autodarts-firstboot.log"
IMAGER_FIRSTRUN_MARKER="$STATE_DIR/imager-firstrun.attempted"
SEED_USED=false

mkdir -p "$STATE_DIR" "$CONFIG_DIR"
touch "$FIRSTBOOT_LOG"

if [[ -f "$SEED_CONFIG" ]]; then
  cp "$SEED_CONFIG" "$CONFIG_FILE"
  SEED_USED=true
fi

config_string() {
  local key="$1"
  awk -F '"' -v key="$key" '$0 ~ "^" key "[[:space:]]*=" {print $2; exit}' "$CONFIG_FILE" 2>/dev/null || true
}

set_config_string() {
  local key="$1"
  local value="$2"
  local escaped
  escaped="$(printf '%s' "$value" | sed 's/\\/\\\\/g; s/"/\\"/g')"
  if grep -qE "^${key}[[:space:]]*=" "$CONFIG_FILE" 2>/dev/null; then
    sed -i -E "s|^${key}[[:space:]]*=.*|${key} = \"${escaped}\"|" "$CONFIG_FILE"
  else
    printf '%s = "%s"\n' "$key" "$escaped" >> "$CONFIG_FILE"
  fi
}

set_config_bool() {
  local key="$1"
  local value="$2"
  if grep -qE "^${key}[[:space:]]*=" "$CONFIG_FILE" 2>/dev/null; then
    sed -i -E "s|^${key}[[:space:]]*=.*|${key} = ${value}|" "$CONFIG_FILE"
  else
    printf '%s = %s\n' "$key" "$value" >> "$CONFIG_FILE"
  fi
}

json_string() {
  printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g; s/\r//g' | tr '\n' ' '
}

write_firstboot_status() {
  local state="$1"
  local message="$2"
  mkdir -p "$(dirname "$STATUS_FILE")"
  cat > "$STATUS_FILE" <<EOF
{
  "firstboot": {
    "state": "$(json_string "$state")",
    "message": "$(json_string "$message")"
  }
}
EOF
}

run_imager_firstrun_fallback() {
  local rc firstrun
  firstrun=""
  for candidate in /boot/firmware/firstrun.sh /boot/firstrun.sh; do
    if [[ -f "$candidate" ]]; then
      firstrun="$candidate"
      break
    fi
  done
  [[ -n "$firstrun" ]] || return 0
  [[ ! -f "$IMAGER_FIRSTRUN_MARKER" ]] || return 0

  echo "$(date -Is) Raspberry Pi Imager firstrun.sh found; running compatibility fallback." >> "$FIRSTBOOT_LOG"
  touch "$IMAGER_FIRSTRUN_MARKER"
  chmod +x "$firstrun" || true
  set +e
  bash "$firstrun" >> "$FIRSTBOOT_LOG" 2>&1
  rc=$?
  set -e

  if [[ "$rc" -eq 0 ]]; then
    write_firstboot_status "ok" "Raspberry Pi Imager firstrun.sh wurde ausgefuehrt."
  else
    write_firstboot_status "warning" "Raspberry Pi Imager firstrun.sh konnte nicht erfolgreich ausgefuehrt werden. Autodarts Pi OS startet den normalen Setup-Fallback."
    echo "$(date -Is) Raspberry Pi Imager firstrun.sh failed with code $rc." >> "$FIRSTBOOT_LOG"
  fi
}

if [[ ! -f "$SETUP_STATE" ]]; then
  echo "factory" > "$SETUP_STATE"
fi

run_imager_firstrun_fallback

existing_groups() {
  local groups=()
  local group
  for group in video input render gpio netdev tty audio; do
    if getent group "$group" >/dev/null 2>&1; then
      groups+=("$group")
    fi
  done
  (IFS=,; echo "${groups[*]}")
}

GROUPS="$(existing_groups)"
if ! id autodarts >/dev/null 2>&1; then
  if [[ -n "$GROUPS" ]]; then
    useradd -m -s /bin/bash -G "$GROUPS" autodarts
  else
    useradd -m -s /bin/bash autodarts
  fi
else
  chsh -s /bin/bash autodarts || true
  if [[ -n "$GROUPS" ]]; then
    usermod -aG "$GROUPS" autodarts || true
  fi
fi
echo "autodarts:autodarts" | chpasswd
install -m 0644 "$CONFIG_DIR/bash_profile" /home/autodarts/.bash_profile
install -m 0644 "$CONFIG_DIR/bash_profile" /home/autodarts/.profile
touch /home/autodarts/.hushlogin
install -d -m 0700 -o autodarts -g autodarts /home/autodarts/.cache
install -d -m 0700 -o autodarts -g autodarts /home/autodarts/.config
install -d -m 0700 -o autodarts -g autodarts /home/autodarts/.local/state/autodarts-pi-os
chown -R autodarts:autodarts /home/autodarts || true

if systemctl list-unit-files NetworkManager.service >/dev/null 2>&1; then
  systemctl enable NetworkManager.service || true
  systemctl start NetworkManager.service || true
fi

if [[ -f /boot/firmware/ssh || -f /boot/firmware/ssh.txt || -f /boot/ssh || -f /boot/ssh.txt ]]; then
  systemctl enable ssh.service >/dev/null 2>&1 || systemctl enable ssh >/dev/null 2>&1 || true
  systemctl start ssh.service >/dev/null 2>&1 || systemctl start ssh >/dev/null 2>&1 || true
fi

CURRENT_HOSTNAME="$(hostnamectl --static status 2>/dev/null || hostname 2>/dev/null || true)"
HOSTNAME="$(config_string hostname)"
if [[ "$SEED_USED" != "true" && -n "$CURRENT_HOSTNAME" && "$CURRENT_HOSTNAME" != "raspberrypi" && "$CURRENT_HOSTNAME" != "$HOSTNAME" ]]; then
  set_config_string hostname "$CURRENT_HOSTNAME"
elif [[ -n "$HOSTNAME" ]]; then
  hostnamectl set-hostname "$HOSTNAME" || true
elif [[ -n "$CURRENT_HOSTNAME" ]]; then
  set_config_string hostname "$CURRENT_HOSTNAME"
fi

if nmcli -t -f NAME,TYPE connection show 2>/dev/null | awk -F ':' '$2 == "802-11-wireless" && $1 != "Autodarts-Setup" { found=1 } END { exit found ? 0 : 1 }'; then
  SSID="$(nmcli -t -f NAME,TYPE connection show 2>/dev/null | awk -F ':' '$2 == "802-11-wireless" && $1 != "Autodarts-Setup" { print $1; exit }')"
  set_config_string wifi_ssid "$SSID"
  cat > "$STATUS_FILE" <<EOF
{
  "wifi": {
    "state": "pending",
    "message": "WLAN wurde ueber Raspberry Pi Imager vorkonfiguriert. Sobald die Verbindung steht, wird das Setup automatisch abgeschlossen. Wenn sie fehlschlaegt, startet der Setup-Hotspot.",
    "ssid": "$(json_string "$SSID")",
    "assigned_ip": "",
    "stdout": "Raspberry Pi Imager NetworkManager profile detected.",
    "stderr": ""
  }
}
EOF
fi

touch "$STATE_DIR/firstboot.done"
