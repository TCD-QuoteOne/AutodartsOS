#!/usr/bin/env bash
set -euo pipefail

STATE_DIR="/var/lib/autodarts-pi-os"
CONFIG_DIR="/etc/autodarts-pi-os"
SEED_CONFIG="/boot/firmware/autodarts-config.toml"
CONFIG_FILE="$CONFIG_DIR/config.toml"
SETUP_STATE="$STATE_DIR/setup.state"
STATUS_FILE="$STATE_DIR/setup-status.json"
FIRSTBOOT_LOG="/var/log/autodarts-firstboot.log"
IMAGER_FIRSTRUN_MARKER="$STATE_DIR/imager-firstrun.attempted"
WIFI_APPLY_REQUEST="$STATE_DIR/wifi-apply.request"
WIFI_CREDENTIALS="$STATE_DIR/wifi-credentials.json"
SEED_USED=false

mkdir -p "$STATE_DIR" "$CONFIG_DIR"
touch "$FIRSTBOOT_LOG"

if [[ -f "$SEED_CONFIG" ]]; then
  cp "$SEED_CONFIG" "$CONFIG_FILE"
  SEED_USED=true
fi

secure_root_autodarts_file() {
  local path="$1"
  [[ -e "$path" ]] || return 0
  chown root:autodarts "$path" 2>/dev/null || true
  chmod 0640 "$path" 2>/dev/null || true
}

config_string() {
  local key="$1"
  awk -F '"' -v key="$key" '$0 ~ "^" key "[[:space:]]*=" {print $2; exit}' "$CONFIG_FILE" 2>/dev/null || true
}

sanitize_hostname() {
  local value="$1"
  value="$(printf '%s' "$value" | tr '[:upper:]' '[:lower:]' | sed -E 's/[^a-z0-9-]+/-/g; s/-+/-/g; s/^-//; s/-$//')"
  value="${value:0:63}"
  value="$(printf '%s' "$value" | sed -E 's/-$//')"
  printf '%s' "${value:-autodarts-pi}"
}

set_config_string() {
  local key="$1"
  local value="$2"
  local escaped
  escaped="$(printf '%s' "$value" | sed 's/\\/\\\\/g; s/"/\\"/g')"
  if grep -qE "^${key}[[:space:]]*=" "$CONFIG_FILE" 2>/dev/null; then
    sed -i -E "s|^${key}[[:space:]]*=.*|${key} = \"${escaped}\"|" "$CONFIG_FILE"
  else
    printf '%s = "%s"\n' "$key" "$escaped" >> "$CONFIG_FILE"
  fi
}

set_config_bool() {
  local key="$1"
  local value="$2"
  if grep -qE "^${key}[[:space:]]*=" "$CONFIG_FILE" 2>/dev/null; then
    sed -i -E "s|^${key}[[:space:]]*=.*|${key} = ${value}|" "$CONFIG_FILE"
  else
    printf '%s = %s\n' "$key" "$value" >> "$CONFIG_FILE"
  fi
}

ensure_hosts_entry() {
  local hostname="$1"
  [[ -n "$hostname" ]] || return 0

  touch /etc/hosts
  if grep -qE '^[[:space:]]*127\.0\.1\.1[[:space:]]+' /etc/hosts; then
    sed -i -E "s/^[[:space:]]*127\.0\.1\.1[[:space:]].*/127.0.1.1\t${hostname}/" /etc/hosts
  else
    printf '127.0.1.1\t%s\n' "$hostname" >> /etc/hosts
  fi
}

json_string() {
  printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g; s/\r//g' | tr '\n' ' '
}

json_file_string() {
  python3 -c 'import json,sys; print(json.dumps(sys.stdin.read().strip()))' 2>/dev/null || {
    local value
    value="$(cat)"
    printf '"%s"' "$(printf '%s' "$value" | sed 's/\\/\\\\/g; s/"/\\"/g')"
  }
}

write_firstboot_status() {
  local state="$1"
  local message="$2"
  mkdir -p "$(dirname "$STATUS_FILE")"
  cat > "$STATUS_FILE" <<EOF
{
  "firstboot": {
    "state": "$(json_string "$state")",
    "message": "$(json_string "$message")"
  }
}
EOF
}

disable_imager_firstrun() {
  local candidate target

  for candidate in /boot/firmware/firstrun.sh /boot/firstrun.sh; do
    if [[ -f "$candidate" ]]; then
      target="${candidate}.autodarts-disabled"
      mv "$candidate" "$target" 2>/dev/null || rm -f "$candidate" || true
      echo "$(date -Is) Disabled Raspberry Pi Imager firstrun script at $candidate." >> "$FIRSTBOOT_LOG"
    fi
  done

  for candidate in /boot/firmware/cmdline.txt /boot/cmdline.txt; do
    [[ -f "$candidate" ]] || continue
    python3 - "$candidate" <<'PY' 2>/dev/null || true
import sys

path = sys.argv[1]
text = open(path, encoding="utf-8", errors="replace").read().strip()
if not text:
    sys.exit(0)

drop_prefixes = (
    "systemd.run=",
    "systemd.run_success_action=",
    "systemd.run_failure_action=",
)
drop_values = {
    "systemd.unit=kernel-command-line.target",
}
tokens = []
changed = False
for token in text.split():
    if token in drop_values or any(token.startswith(prefix) for prefix in drop_prefixes):
        changed = True
        continue
    tokens.append(token)

if changed:
    open(path, "w", encoding="utf-8").write(" ".join(tokens) + "\n")
PY
  done
}

run_imager_firstrun_fallback() {
  local firstrun
  firstrun=""
  for candidate in /boot/firmware/firstrun.sh /boot/firstrun.sh; do
    if [[ -f "$candidate" ]]; then
      firstrun="$candidate"
      break
    fi
  done
  [[ -n "$firstrun" ]] || return 0
  [[ ! -f "$IMAGER_FIRSTRUN_MARKER" ]] || return 0

  echo "$(date -Is) Raspberry Pi Imager firstrun.sh found; Autodarts Pi OS imports supported values and disables the upstream first-run hook." >> "$FIRSTBOOT_LOG"
  touch "$IMAGER_FIRSTRUN_MARKER"
  disable_imager_firstrun
  write_firstboot_status "ok" "Raspberry Pi Imager Anpassungen wurden uebernommen und der Imager-Erststart wurde deaktiviert."
}

import_imager_firstrun_credentials() {
  local firstrun parsed ssid psk country
  firstrun=""
  for candidate in /boot/firmware/firstrun.sh /boot/firstrun.sh; do
    if [[ -f "$candidate" ]]; then
      firstrun="$candidate"
      break
    fi
  done
  [[ -n "$firstrun" ]] || return 0

  parsed="$(python3 - "$firstrun" <<'PY' 2>/dev/null || true
import re
import shlex
import sys

path = sys.argv[1]
text = open(path, encoding="utf-8", errors="replace").read()
logical_lines = []
current = ""
for raw in text.splitlines():
    line = raw.strip()
    if not line or line.startswith("#"):
        continue
    if line.endswith("\\"):
        current += line[:-1] + " "
        continue
    logical_lines.append(current + line)
    current = ""
if current:
    logical_lines.append(current)

ssid = password = country = ""
for line in logical_lines:
    try:
        tokens = shlex.split(line)
    except Exception:
        tokens = line.split()
    for idx, token in enumerate(tokens):
        if token == "connect" and idx > 1 and idx + 1 < len(tokens) and tokens[idx - 1] == "wifi":
            ssid = tokens[idx + 1]
        elif token == "ssid" and idx + 1 < len(tokens):
            ssid = tokens[idx + 1]
        elif token in {"password", "wifi-sec.psk", "psk"} and idx + 1 < len(tokens):
            password = tokens[idx + 1]
        elif token == "wifi-sec.psk:" and idx + 1 < len(tokens):
            password = tokens[idx + 1]
    for idx, token in enumerate(tokens):
        if token in {"--ssid", "--wifi-ssid"} and idx + 1 < len(tokens):
            ssid = tokens[idx + 1]
        elif token.startswith("--ssid="):
            ssid = token.split("=", 1)[1]
        elif token.startswith("--wifi-ssid="):
            ssid = token.split("=", 1)[1]
        elif token in {"--wifi-password", "--password", "--psk"} and idx + 1 < len(tokens):
            password = tokens[idx + 1]
        elif token.startswith("--wifi-password="):
            password = token.split("=", 1)[1]
        elif token.startswith("--psk="):
            password = token.split("=", 1)[1]
        elif token in {"--wifi-country", "--country"} and idx + 1 < len(tokens):
            country = tokens[idx + 1]
        elif token.startswith("--wifi-country="):
            country = token.split("=", 1)[1]

if not ssid:
    match = re.search(r'\bssid\s*=\s*["\']?([^"\'\n]+)', text)
    if match:
        ssid = match.group(1).strip()
if not password:
    match = re.search(r'\b(?:psk|wifi_password|password)\s*=\s*["\']?([^"\'\n]+)', text)
    if match:
        password = match.group(1).strip()
if not country:
    match = re.search(r'\b(?:country|wifi_country)\s*=\s*["\']?([A-Za-z]{2})', text)
    if match:
        country = match.group(1).strip()

if ssid and password:
    print("\t".join([ssid, password, (country or "DE").upper()[:2]]))
PY
)"
  [[ -n "$parsed" ]] || return 0
  IFS=$'\t' read -r ssid psk country <<< "$parsed"
  country="${country:-DE}"

  echo "$(date -Is) Importing Raspberry Pi Imager WiFi credentials from $firstrun for SSID '$ssid'." >> "$FIRSTBOOT_LOG"
  set_config_string wifi_ssid "$ssid"
  set_config_string wifi_password "$psk"
  set_config_string wifi_country "$country"

  mkdir -p "$STATE_DIR"
  cat > "$WIFI_CREDENTIALS" <<EOF
{
  "ssid": $(printf '%s' "$ssid" | json_file_string),
  "password": $(printf '%s' "$psk" | json_file_string),
  "country": $(printf '%s' "$country" | json_file_string),
  "password_saved": true,
  "source": "raspberry-pi-imager-firstrun"
}
EOF
  chmod 0600 "$WIFI_CREDENTIALS"
  printf 'pending\n' > "$WIFI_APPLY_REQUEST"
}

import_imager_wpa_supplicant() {
  local source ssid psk country
  source=""
  for candidate in \
    /boot/firmware/wpa_supplicant.conf \
    /boot/wpa_supplicant.conf \
    /etc/wpa_supplicant/wpa_supplicant.conf; do
    if [[ -f "$candidate" ]]; then
      source="$candidate"
      break
    fi
  done
  [[ -n "$source" ]] || return 0

  ssid="$(awk -F '"' '/^[[:space:]]*ssid=/{print $2; exit}' "$source" 2>/dev/null || true)"
  psk="$(awk -F '"' '/^[[:space:]]*psk=/{print $2; exit}' "$source" 2>/dev/null || true)"
  country="$(awk -F '=' '/^[[:space:]]*country=/{gsub(/[[:space:]]/, "", $2); print toupper($2); exit}' "$source" 2>/dev/null || true)"
  country="${country:-DE}"

  if [[ -z "$ssid" || -z "$psk" ]]; then
    echo "$(date -Is) Imager wpa_supplicant file found at $source, but SSID or PSK is missing." >> "$FIRSTBOOT_LOG"
    return 0
  fi

  echo "$(date -Is) Importing Raspberry Pi Imager WiFi credentials from $source for SSID '$ssid'." >> "$FIRSTBOOT_LOG"
  set_config_string wifi_ssid "$ssid"
  set_config_string wifi_password "$psk"
  set_config_string wifi_country "$country"

  mkdir -p "$STATE_DIR"
  cat > "$WIFI_CREDENTIALS" <<EOF
{
  "ssid": $(printf '%s' "$ssid" | json_file_string),
  "password": $(printf '%s' "$psk" | json_file_string),
  "country": $(printf '%s' "$country" | json_file_string),
  "password_saved": true,
  "source": "raspberry-pi-imager"
}
EOF
  chmod 0600 "$WIFI_CREDENTIALS"
  printf 'pending\n' > "$WIFI_APPLY_REQUEST"
  cat > "$STATUS_FILE" <<EOF
{
  "wifi": {
    "state": "pending",
    "message": "WLAN wurde aus Raspberry Pi Imager importiert und wird beim ersten Boot getestet.",
    "ssid": "$(json_string "$ssid")",
    "assigned_ip": "",
    "stdout": "Imported from $source.",
    "stderr": ""
  }
}
EOF
}

import_imager_nm_connections() {
  local source ssid psk country
  source=""
  shopt -s nullglob
  for candidate in /etc/NetworkManager/system-connections/*.nmconnection; do
    if grep -qE '^\[wifi\]' "$candidate" 2>/dev/null && ! grep -qE '^id=Autodarts-Setup$' "$candidate" 2>/dev/null; then
      source="$candidate"
      break
    fi
  done
  shopt -u nullglob
  [[ -n "$source" ]] || return 0

  ssid="$(awk -F '=' '/^[[:space:]]*ssid=/{print substr($0, index($0, "=") + 1); exit}' "$source" 2>/dev/null || true)"
  psk="$(awk -F '=' '/^[[:space:]]*psk=/{print substr($0, index($0, "=") + 1); exit}' "$source" 2>/dev/null || true)"
  country="$(config_string wifi_country)"
  country="${country:-DE}"

  if [[ -z "$ssid" || -z "$psk" ]]; then
    echo "$(date -Is) Imager NetworkManager profile found at $source, but SSID or PSK is missing." >> "$FIRSTBOOT_LOG"
    return 0
  fi

  echo "$(date -Is) Importing Raspberry Pi Imager WiFi credentials from NetworkManager profile $source for SSID '$ssid'." >> "$FIRSTBOOT_LOG"
  set_config_string wifi_ssid "$ssid"
  set_config_string wifi_password "$psk"
  set_config_string wifi_country "$country"

  mkdir -p "$STATE_DIR"
  cat > "$WIFI_CREDENTIALS" <<EOF
{
  "ssid": $(printf '%s' "$ssid" | json_file_string),
  "password": $(printf '%s' "$psk" | json_file_string),
  "country": $(printf '%s' "$country" | json_file_string),
  "password_saved": true,
  "source": "raspberry-pi-imager-networkmanager"
}
EOF
  chmod 0600 "$WIFI_CREDENTIALS"
  printf 'pending\n' > "$WIFI_APPLY_REQUEST"
  cat > "$STATUS_FILE" <<EOF
{
  "wifi": {
    "state": "pending",
    "message": "WLAN wurde aus Raspberry Pi Imager importiert und wird beim ersten Boot getestet.",
    "ssid": "$(json_string "$ssid")",
    "assigned_ip": "",
    "stdout": "Imported from $source.",
    "stderr": ""
  }
}
EOF
}

existing_groups() {
  local groups=()
  local group
  for group in video input render gpio netdev tty audio; do
    if getent group "$group" >/dev/null 2>&1; then
      groups+=("$group")
    fi
  done
  (IFS=,; echo "${groups[*]}")
}

USER_GROUPS="$(existing_groups)"
if ! id autodarts >/dev/null 2>&1; then
  if [[ -n "$USER_GROUPS" ]]; then
    useradd -m -s /bin/bash -G "$USER_GROUPS" autodarts
  else
    useradd -m -s /bin/bash autodarts
  fi
else
  chsh -s /bin/bash autodarts || true
  if [[ -n "$USER_GROUPS" ]]; then
    usermod -aG "$USER_GROUPS" autodarts || true
  fi
fi
passwd -l autodarts >/dev/null 2>&1 || true
install -m 0644 "$CONFIG_DIR/bash_profile" /home/autodarts/.bash_profile
install -m 0644 "$CONFIG_DIR/bash_profile" /home/autodarts/.profile
touch /home/autodarts/.hushlogin
install -d -m 0700 -o autodarts -g autodarts /home/autodarts/.cache
install -d -m 0700 -o autodarts -g autodarts /home/autodarts/.config
install -d -m 0700 -o autodarts -g autodarts /home/autodarts/.local/state/autodarts-pi-os
chown -R autodarts:autodarts /home/autodarts || true
secure_root_autodarts_file "$CONFIG_FILE"
secure_root_autodarts_file "$STATUS_FILE"
secure_root_autodarts_file "$FIRSTBOOT_LOG"

if systemctl list-unit-files NetworkManager.service >/dev/null 2>&1; then
  systemctl enable NetworkManager.service || true
  systemctl start NetworkManager.service || true
  sleep 2
fi

if [[ -f /boot/firmware/ssh || -f /boot/firmware/ssh.txt || -f /boot/ssh || -f /boot/ssh.txt ]]; then
  systemctl enable ssh.service >/dev/null 2>&1 || systemctl enable ssh >/dev/null 2>&1 || true
  systemctl start ssh.service >/dev/null 2>&1 || systemctl start ssh >/dev/null 2>&1 || true
fi

if [[ ! -f "$SETUP_STATE" ]]; then
  echo "factory" > "$SETUP_STATE"
fi

import_imager_firstrun_credentials
run_imager_firstrun_fallback
import_imager_wpa_supplicant
import_imager_nm_connections

CURRENT_HOSTNAME="$(hostnamectl --static status 2>/dev/null || hostname 2>/dev/null || true)"
HOSTNAME="$(config_string hostname)"
CURRENT_HOSTNAME="$(sanitize_hostname "$CURRENT_HOSTNAME")"
HOSTNAME="$(sanitize_hostname "$HOSTNAME")"
if [[ "$SEED_USED" != "true" && -n "$CURRENT_HOSTNAME" && "$CURRENT_HOSTNAME" != "raspberrypi" && "$CURRENT_HOSTNAME" != "$HOSTNAME" ]]; then
  set_config_string hostname "$CURRENT_HOSTNAME"
  hostnamectl set-hostname "$CURRENT_HOSTNAME" || true
  ensure_hosts_entry "$CURRENT_HOSTNAME"
  systemctl restart avahi-daemon.service >/dev/null 2>&1 || true
elif [[ -n "$HOSTNAME" ]]; then
  hostnamectl set-hostname "$HOSTNAME" || true
  ensure_hosts_entry "$HOSTNAME"
  systemctl restart avahi-daemon.service >/dev/null 2>&1 || true
elif [[ -n "$CURRENT_HOSTNAME" ]]; then
  set_config_string hostname "$CURRENT_HOSTNAME"
  hostnamectl set-hostname "$CURRENT_HOSTNAME" || true
  ensure_hosts_entry "$CURRENT_HOSTNAME"
  systemctl restart avahi-daemon.service >/dev/null 2>&1 || true
fi

if nmcli -t -f NAME,TYPE connection show 2>/dev/null | awk -F ':' '$2 == "802-11-wireless" && $1 != "Autodarts-Setup" { found=1 } END { exit found ? 0 : 1 }'; then
  SSID="$(nmcli -t -f NAME,TYPE connection show 2>/dev/null | awk -F ':' '$2 == "802-11-wireless" && $1 != "Autodarts-Setup" { print $1; exit }')"
  set_config_string wifi_ssid "$SSID"
  nmcli radio wifi on >/dev/null 2>&1 || true
  nmcli connection modify "$SSID" connection.autoconnect yes >/dev/null 2>&1 || true
  if [[ -f "$WIFI_CREDENTIALS" ]]; then
    printf 'pending\n' > "$WIFI_APPLY_REQUEST"
  else
    nmcli --wait 30 connection up "$SSID" >/dev/null 2>&1 || true
  fi
  cat > "$STATUS_FILE" <<EOF
{
  "wifi": {
    "state": "pending",
    "message": "WLAN wurde ueber Raspberry Pi Imager vorkonfiguriert. Sobald die Verbindung steht, wird das Setup automatisch abgeschlossen. Wenn sie fehlschlaegt, startet der Setup-Hotspot.",
    "ssid": "$(json_string "$SSID")",
    "assigned_ip": "",
    "stdout": "Raspberry Pi Imager NetworkManager profile detected.",
    "stderr": ""
  }
}
EOF
fi

touch "$STATE_DIR/firstboot.done"
