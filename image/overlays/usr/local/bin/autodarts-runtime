#!/usr/bin/env bash
set -euo pipefail

CONFIG_FILE="/etc/autodarts-pi-os/config.toml"

command_from_config() {
  awk -F '"' '/^autodarts_command[[:space:]]*=/{print $2; exit}' "$CONFIG_FILE" 2>/dev/null || true
}

COMMAND="$(command_from_config)"

if [[ -z "$COMMAND" || "$COMMAND" == "/usr/local/bin/autodarts-runtime" ]]; then
  echo "Autodarts runtime command is not configured yet."
  echo "Set autodarts_command in $CONFIG_FILE when the upstream runtime is installed."
  sleep infinity
fi

exec $COMMAND

