#!/usr/bin/env bash
set -euo pipefail

CONFIG_FILE="/etc/autodarts-pi-os/config.toml"

command_from_config() {
  awk -F '"' '/^autodarts_command[[:space:]]*=/{print $2; exit}' "$CONFIG_FILE" 2>/dev/null || true
}

COMMAND="$(command_from_config)"

if [[ -z "$COMMAND" || "$COMMAND" == "/usr/local/bin/autodarts-runtime" ]]; then
  if systemctl list-unit-files autodarts.service >/dev/null 2>&1; then
    echo "Autodarts is managed by upstream autodarts.service."
    systemctl start autodarts.service || true
    sleep infinity
  fi
  if command -v autodarts >/dev/null 2>&1; then
    exec autodarts
  fi
  echo "Autodarts runtime command is not configured yet and no autodarts binary/service was found."
  echo "Set autodarts_command in $CONFIG_FILE or check /var/log/autodarts-install.log."
  sleep infinity
fi

exec $COMMAND
